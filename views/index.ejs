<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SoulTrader</title>
  <link rel="icon" type="image/x-icon" href="/icons/favicon.ico">
  <link href="https://fonts.googleapis.com/css2?family=Spectral:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/responsive.css">
</head>
<body>
  <%- include('partials/navbar', { title: 'Home', gameKey: '', pendingTradeCount: typeof pendingTradeCount !== 'undefined' ? pendingTradeCount : 0 }) %>

  <div class="main-content">
    <%- include('partials/flash-messages') %>

    <!-- Stats Tracker -->
    <% if (typeof siteStats !== 'undefined') { %>
      <div class="stats-tracker">
        <%
          function fmtStat(n) {
            n = parseInt(n, 10) || 0;
            if (n >= 1000000) return parseFloat((n / 1000000).toFixed(1)) + 'M';
            if (n >= 1000)    return parseFloat((n / 1000).toFixed(1)) + 'K';
            return String(n);
          }
        %>
        <div class="stats-tracker-item">
          <span class="stats-tracker-value"><%= fmtStat(siteStats.totalTrades) %></span>
          <span class="stats-tracker-label">Trades</span>
        </div>
        <div class="stats-tracker-divider"></div>
        <div class="stats-tracker-item">
          <span class="stats-tracker-value"><%= fmtStat(siteStats.totalItems) %></span>
          <span class="stats-tracker-label">Items Traded</span>
        </div>
        <div class="stats-tracker-divider"></div>
        <div class="stats-tracker-item">
          <span class="stats-tracker-value"><%= fmtStat(siteStats.currencyVolume) %></span>
          <span class="stats-tracker-label">Souls Traded</span>
        </div>
        <div class="stats-tracker-divider"></div>
        <div class="stats-tracker-item">
          <span class="stats-tracker-value"><%= fmtStat(siteStats.totalUsers) %></span>
          <span class="stats-tracker-label">Traders</span>
        </div>
      </div>
    <% } %>

    <div class="home-grid">
      <img src="https://i.imgur.com/ZA6Hkr1.png" class="main-image" alt="SoulTrader">
      <div class="game-grid">
        <a href="/eldenring"><img src="https://i.imgur.com/7aq4TkU.png" alt="Elden Ring"></a>
        <a href="/darksouls"><img src="https://i.imgur.com/o0BUvUQ.png" alt="Dark Souls"></a>
        <a href="/darksouls3"><img src="https://i.imgur.com/sETyDch.png" alt="Dark Souls 3"></a>
        <a href="/darksouls2"><img src="https://i.imgur.com/TFHkXED.png" alt="Dark Souls 2"></a>
        <a href="/bloodborne"><img src="https://i.imgur.com/0q8jRGA.png" alt="Bloodborne"></a>
        <a href="/demonssouls"><img src="https://i.imgur.com/R9wKWFE.png" alt="Demon's Souls"></a>
      </div>
    </div>
  </div>

  <%- include('partials/auth-modals') %>
  <%- include('partials/footer') %>

  <script src="/js/auth.js"></script>
</body>
</html>
