<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard | SoulTrader</title>
  <link rel="icon" type="image/png" href="/icons/favicon.png">
  <link href="https://fonts.googleapis.com/css2?family=Spectral:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/responsive.css">
</head>
<body>
  <%- include('../partials/navbar', { title: 'Admin', gameKey: '', pendingTradeCount: typeof pendingTradeCount !== 'undefined' ? pendingTradeCount : 0 }) %>

  <div class="main-content">
    <h1 class="section-title" style="margin-top:0.5rem;">Admin Dashboard</h1>

    <!-- Stats Grid -->
    <div class="admin-stats">
      <div class="stat-card">
        <div class="stat-number"><%= totalUsers %></div>
        <div class="stat-title">Total Users</div>
      </div>
      <div class="stat-card">
        <div class="stat-number"><%= totalTrades %></div>
        <div class="stat-title">Total Trades</div>
      </div>
      <div class="stat-card">
        <div class="stat-number"><%= openTrades %></div>
        <div class="stat-title">Open Trades</div>
      </div>
      <div class="stat-card">
        <div class="stat-number"><%= awaitingTrades %></div>
        <div class="stat-title">Awaiting</div>
      </div>
      <div class="stat-card">
        <div class="stat-number"><%= completedTrades %></div>
        <div class="stat-title">Completed</div>
      </div>
      <div class="stat-card">
        <div class="stat-number" style="color: var(--danger);"><%= bannedUsers %></div>
        <div class="stat-title">Banned</div>
      </div>
      <% if (typeof pendingReportCount !== 'undefined') { %>
        <a href="/admin/reports" class="stat-card" style="text-decoration:none; color:inherit; border-color: <%= pendingReportCount > 0 ? 'rgba(231, 76, 60, 0.4)' : 'var(--border-color)' %>;">
          <div class="stat-number" style="color: <%= pendingReportCount > 0 ? 'var(--danger)' : 'var(--text-primary)' %>;"><%= pendingReportCount %></div>
          <div class="stat-title">Pending Reports</div>
        </a>
      <% } %>
    </div>

    <!-- Trades by Game -->
    <h2 style="margin:2rem 0 1rem;">Trades by Game</h2>
    <div class="admin-stats">
      <% tradesByGame.forEach(entry => { %>
        <div class="stat-card">
          <div class="stat-number"><%= entry.count %></div>
          <div class="stat-title"><%= entry.game %></div>
        </div>
      <% }); %>
    </div>

    <!-- Recent Users -->
    <h2 style="margin:2rem 0 1rem;">Recent Users</h2>
    <div style="overflow-x:auto;">
      <table style="width:100%; border-collapse:collapse; font-size:0.85rem;">
        <thead>
          <tr style="border-bottom:1px solid var(--border-color); text-align:left;">
            <th style="padding:0.75rem 0.5rem;">Username</th>
            <th style="padding:0.75rem 0.5rem;">Email</th>
            <th style="padding:0.75rem 0.5rem;">Role</th>
            <th style="padding:0.75rem 0.5rem;">Status</th>
            <th style="padding:0.75rem 0.5rem;">Joined</th>
            <th style="padding:0.75rem 0.5rem;">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% recentUsers.forEach(user => { %>
            <tr style="border-bottom:1px solid var(--border-subtle);">
              <td style="padding:0.5rem;">
                <a href="/profile/<%= user.username %>" style="color:var(--accent);"><%= user.username %></a>
              </td>
              <td style="padding:0.5rem; color:var(--text-muted);"><%= user.email %></td>
              <td style="padding:0.5rem;"><%= user.role %></td>
              <td style="padding:0.5rem;">
                <% if (user.isBanned) { %>
                  <span class="status-badge status-declined">Banned</span>
                <% } else { %>
                  <span class="status-badge status-open">Active</span>
                <% } %>
              </td>
              <td style="padding:0.5rem; color:var(--text-muted);"><%= user.createdAt.toLocaleDateString() %></td>
              <td style="padding:0.5rem;">
                <div style="display:flex; gap:0.25rem; flex-wrap:wrap;">
                  <% if (!user.isBanned) { %>
                    <button class="btn btn-danger btn-sm" onclick="adminAction('/admin/users/<%= user.id %>/ban', 'POST', {reason:'Admin action'})">Ban</button>
                  <% } else { %>
                    <button class="btn btn-success btn-sm" onclick="adminAction('/admin/users/<%= user.id %>/unban', 'POST')">Unban</button>
                  <% } %>
                  <select onchange="if(this.value) adminAction('/admin/users/<%= user.id %>/role', 'POST', {role:this.value}); this.selectedIndex=0;" style="padding:0.2rem; font-size:0.75rem; background:var(--bg-input); color:var(--text-primary); border:1px solid var(--border-color); border-radius:4px;">
                    <option value="">Role...</option>
                    <option value="user">User</option>
                    <option value="moderator">Mod</option>
                    <option value="admin">Admin</option>
                  </select>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <%- include('../partials/preloader') %>
  <%- include('../partials/footer') %>

  <script>
    async function adminAction(url, method, body) {
      try {
        const opts = {
          method,
          headers: { 'Content-Type': 'application/json' },
        };
        if (body) opts.body = JSON.stringify(body);

        const resp = await fetch(url, opts);
        const data = await resp.json();

        if (data.success) {
          alert(data.message);
          window.location.reload();
        } else {
          alert(data.error || 'Action failed.');
        }
      } catch (err) {
        console.error('Admin action error:', err);
        alert('An error occurred.');
      }
    }
  </script>
</body>
</html>
