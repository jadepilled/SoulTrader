<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin: Conversation | SoulTrader</title>
  <link rel="icon" type="image/x-icon" href="/icons/favicon.ico">
  <link href="https://fonts.googleapis.com/css2?family=Spectral:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/responsive.css">
  <style>
    .admin-convo-header {
      display: flex; align-items: center; gap: 1rem;
      padding: 0.85rem 1rem;
      background: rgba(18, 18, 18, 0.72);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: var(--radius);
      margin-bottom: 1rem;
    }
    .admin-convo-header a { text-decoration: none; font-weight: 700; }
    .message-list {
      display: flex; flex-direction: column; gap: 0.65rem;
      max-height: 70vh; overflow-y: auto; padding: 1rem;
      background: rgba(18, 18, 18, 0.72);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: var(--radius);
    }
    .message-bubble {
      max-width: 80%; padding: 0.65rem 0.85rem;
      border-radius: var(--radius); position: relative;
    }
    .msg-from-user1 {
      align-self: flex-start;
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.08);
    }
    .msg-from-user2 {
      align-self: flex-end;
      background: rgba(200, 168, 78, 0.12);
      border: 1px solid rgba(200, 168, 78, 0.2);
    }
    .message-sender-name { font-size: 0.75rem; font-weight: 700; }
    .message-content { font-size: 0.85rem; line-height: 1.45; word-wrap: break-word; margin-top: 0.2rem; }
    .message-time { font-size: 0.68rem; color: var(--text-muted); margin-top: 0.3rem; }
    .message-deleted-indicator {
      font-style: italic; color: var(--text-muted); font-size: 0.82rem;
    }
    .message-deleted-badge {
      font-size: 0.65rem; color: var(--danger); font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.3px; margin-left: 0.4rem;
    }
  </style>
</head>
<body>
  <%- include('../partials/navbar', { title: 'Admin Conversation', gameKey: '', pendingTradeCount: typeof pendingTradeCount !== 'undefined' ? pendingTradeCount : 0 }) %>

  <div class="main-content">
    <a href="/admin/reports" style="display:inline-block; color:var(--text-muted); font-size:0.82rem; text-decoration:none; margin-bottom:1rem;">&larr; Back to Reports</a>

    <div class="admin-convo-header">
      <span style="color:var(--text-muted); font-size:0.82rem;">Conversation between</span>
      <a href="/profile/<%= user1.username %>" style="<%= getUsernameStyle(user1.role || 'user') %>"><%= user1.username %></a>
      <span style="color:var(--text-muted);">&amp;</span>
      <a href="/profile/<%= user2.username %>" style="<%= getUsernameStyle(user2.role || 'user') %>"><%= user2.username %></a>
    </div>

    <div class="message-list">
      <% if (messages && messages.length > 0) { %>
        <% messages.forEach(msg => { %>
          <div class="message-bubble <%= msg.senderId === user1.id ? 'msg-from-user1' : 'msg-from-user2' %>">
            <span class="message-sender-name" style="<%= getUsernameStyle(msg.sender ? msg.sender.role : 'user') %>"><%= msg.sender ? msg.sender.username : 'Unknown' %></span>
            <% if (msg.deletedAt) { %>
              <span class="message-deleted-badge">DELETED</span>
            <% } %>
            <div class="message-content<%= msg.deletedAt ? ' message-deleted-indicator' : '' %>"><%= msg.content %></div>
            <div class="message-time"><%= msg.createdAt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' }) %></div>
          </div>
        <% }); %>
      <% } else { %>
        <p style="color:var(--text-muted); font-style:italic; text-align:center; padding:2rem 0;">No messages found.</p>
      <% } %>
    </div>
  </div>

  <%- include('../partials/footer') %>
</body>
</html>
