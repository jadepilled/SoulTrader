<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reset Password | SoulTrader</title>
  <link rel="icon" type="image/x-icon" href="/icons/favicon.ico">
  <link href="https://fonts.googleapis.com/css2?family=Spectral:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/responsive.css">
</head>
<body>
  <%- include('../partials/navbar', { title: 'Reset Password', gameKey: '' }) %>

  <div class="main-content">
    <div class="auth-page-container">
      <div class="auth-card">
        <h1 class="auth-card-title">Set New Password</h1>

        <%- include('../partials/flash-messages') %>

        <form action="/auth/reset-password/<%= token %>" method="POST" style="margin-top:1.25rem;">
          <label for="newPassword">New Password</label>
          <input
            type="password"
            id="newPassword"
            name="password"
            minlength="8"
            placeholder="At least 8 characters"
            required
            style="margin-top:0.4rem;"
          />

          <label for="confirmPassword" style="margin-top:1rem; display:block;">Confirm Password</label>
          <input
            type="password"
            id="confirmPassword"
            name="confirmPassword"
            minlength="8"
            placeholder="Repeat your new password"
            required
            style="margin-top:0.4rem;"
          />

          <button type="submit" class="btn btn-primary btn-full" style="margin-top:1.25rem;">
            Reset Password
          </button>
        </form>
      </div>
    </div>
  </div>

  <%- include('../partials/auth-modals') %>
  <%- include('../partials/footer') %>
  <script src="/js/auth.js"></script>
</body>
</html>
