<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Forgot Password | SoulTrader</title>
  <link rel="icon" type="image/x-icon" href="/icons/favicon.ico">
  <link href="https://fonts.googleapis.com/css2?family=Spectral:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/responsive.css">
</head>
<body>
  <%- include('../partials/navbar', { title: 'Forgot Password', gameKey: '' }) %>

  <div class="main-content">
    <div class="auth-page-container">
      <div class="auth-card">
        <h1 class="auth-card-title">Reset Password</h1>

        <%- include('../partials/flash-messages') %>

        <% if (query && query.signup === 'resetSent') { %>
          <p class="auth-card-subtitle">Check your inbox for a reset link. It expires in 1 hour.</p>
          <p style="text-align:center; margin-top:1.5rem;">
            <a href="/" class="btn btn-primary">Back to Home</a>
          </p>
        <% } else { %>
          <p class="auth-card-subtitle">Enter the email address on your account and we'll send you a reset link.</p>

          <form action="/auth/forgot-password" method="POST" style="margin-top:1.5rem;">
            <label for="resetEmail">Email Address</label>
            <input
              type="email"
              id="resetEmail"
              name="email"
              placeholder="you@example.com"
              required
              style="margin-top:0.4rem;"
            />
            <button type="submit" class="btn btn-primary btn-full" style="margin-top:1rem;">
              Send Reset Link
            </button>
          </form>

          <p style="text-align:center; margin-top:1.25rem; font-size:0.85rem; color:var(--text-muted);">
            Remembered it? <a href="/" class="modal-link" data-open-modal="loginModal">Log in</a>
          </p>
        <% } %>
      </div>
    </div>
  </div>

  <%- include('../partials/auth-modals') %>
  <%- include('../partials/footer') %>
  <script src="/js/auth.js"></script>
</body>
</html>
