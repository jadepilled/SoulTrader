<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Chat with <%= otherUser.username %> | SoulTrader</title>
  <link rel="icon" type="image/png" href="/icons/favicon.png">
  <link href="https://fonts.googleapis.com/css2?family=Spectral:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/responsive.css">
  <style>
    .chat-back-link {
      display: inline-block;
      color: var(--text-muted);
      font-size: 0.82rem;
      text-decoration: none;
      margin-bottom: 1rem;
      transition: color 0.2s;
    }
    .chat-back-link:hover { color: var(--text); }

    .chat-partner {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.85rem 1rem;
      background: rgba(18, 18, 18, 0.72);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: var(--radius);
      margin-bottom: 1rem;
    }
    .chat-partner-avatar {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      object-fit: cover;
    }
    .chat-partner-avatar-fallback {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.08);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.9rem;
      font-weight: 700;
      color: var(--text-muted);
    }
    .chat-partner-name {
      font-weight: 700;
      font-size: 0.95rem;
      text-decoration: none;
    }
    .chat-partner-role {
      font-size: 0.68rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--text-muted);
      margin-left: 0.25rem;
    }

    .message-list {
      display: flex;
      flex-direction: column;
      gap: 0.65rem;
      max-height: 60vh;
      overflow-y: auto;
      padding: 1rem;
      background: rgba(18, 18, 18, 0.72);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: var(--radius);
      margin-bottom: 1rem;
    }

    .message-bubble {
      max-width: 75%;
      padding: 0.65rem 0.85rem;
      border-radius: var(--radius);
      position: relative;
    }
    .message-received {
      align-self: flex-start;
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.08);
    }
    .message-sent {
      align-self: flex-end;
      background: rgba(200, 168, 78, 0.12);
      border: 1px solid rgba(200, 168, 78, 0.2);
    }
    .message-sender-row {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      margin-bottom: 0.25rem;
    }
    .message-sender-avatar {
      width: 20px;
      height: 20px;
      border-radius: 50%;
      object-fit: cover;
    }
    .message-sender-avatar-fallback {
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.08);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.55rem;
      font-weight: 700;
      color: var(--text-muted);
    }
    .message-sender-name {
      font-size: 0.75rem;
      font-weight: 700;
    }
    .message-content {
      font-size: 0.85rem;
      line-height: 1.45;
      word-wrap: break-word;
    }
    .message-time {
      font-size: 0.68rem;
      color: var(--text-muted);
      margin-top: 0.3rem;
    }

    .message-action-btn {
      position: absolute;
      top: 0.4rem;
      right: 0.4rem;
      background: none;
      border: none;
      color: var(--text-muted);
      cursor: pointer;
      font-size: 0.7rem;
      opacity: 0;
      transition: opacity 0.2s, color 0.2s;
      padding: 0.15rem 0.3rem;
    }
    .message-received:hover .message-action-btn,
    .message-sent:hover .message-action-btn {
      opacity: 1;
    }
    .message-action-btn:hover {
      color: var(--danger, #e74c3c);
    }
    .message-deleted {
      font-style: italic;
      color: var(--text-muted);
      opacity: 0.6;
    }

    .report-inline-form {
      display: none;
      margin-top: 0.5rem;
      padding: 0.5rem;
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: var(--radius);
    }
    .report-inline-form.open { display: block; }
    .report-inline-form textarea {
      width: 100%;
      font-size: 0.8rem;
      resize: vertical;
      min-height: 2.5rem;
    }
    .report-inline-form .report-actions {
      display: flex;
      justify-content: flex-end;
      gap: 0.5rem;
      margin-top: 0.35rem;
    }
    .report-cancel-btn {
      background: none;
      border: none;
      color: var(--text-muted);
      cursor: pointer;
      font-size: 0.75rem;
    }

    .compose-form {
      background: rgba(18, 18, 18, 0.72);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: var(--radius);
      padding: 1rem;
    }
    .compose-form textarea {
      width: 100%;
      resize: vertical;
      min-height: 3rem;
    }
    .compose-footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 0.5rem;
    }
    .char-counter {
      font-size: 0.72rem;
      color: var(--text-muted);
    }
    .empty-chat {
      color: var(--text-muted);
      font-style: italic;
      text-align: center;
      padding: 2rem 0;
    }
  </style>
</head>
<body>
  <%- include('../partials/navbar', { title: 'Chat with ' + otherUser.username, gameKey: '', pendingTradeCount: typeof pendingTradeCount !== 'undefined' ? pendingTradeCount : 0 }) %>

  <div class="main-content">
    <%- include('../partials/flash-messages') %>

    <a href="/messages" class="chat-back-link">&larr; Back to Messages</a>

    <!-- Chat Partner Info -->
    <div class="chat-partner">
      <% if (otherUser.profileImagePath) { %>
        <img src="<%= otherUser.profileImagePath %>" class="chat-partner-avatar" alt="" onerror="this.style.display='none'">
      <% } else { %>
        <div class="chat-partner-avatar-fallback"><%= otherUser.username.charAt(0).toUpperCase() %></div>
      <% } %>
      <div>
        <a href="/profile/<%= otherUser.username %>" class="chat-partner-name user-hover-trigger" data-username="<%= otherUser.username %>" style="<%= getUsernameStyle(otherUser.role || 'user') %>"><%= otherUser.username %></a>
        <% if (otherUser.role && otherUser.role !== 'user') { %>
          <span class="chat-partner-role"><%= otherUser.role %></span>
        <% } %>
      </div>
    </div>

    <!-- Message List -->
    <div class="message-list" id="messageList">
      <% if (typeof messages !== 'undefined' && messages.length > 0) { %>
        <% messages.forEach(msg => { %>
          <% const isSent = msg.senderId === userId; %>
          <div class="message-bubble <%= isSent ? 'message-sent' : 'message-received' %><%= msg.deletedAt ? ' message-deleted' : '' %>" id="msg-<%= msg.id %>">
            <% if (msg.deletedAt) { %>
              <div class="message-sender-row">
                <% const sender = isSent ? currentUser : otherUser; %>
                <a href="/profile/<%= sender.username %>" class="message-sender-name user-hover-trigger" data-username="<%= sender.username %>" style="<%= getUsernameStyle(sender.role || 'user') %>; text-decoration:none;"><%= sender.username %></a>
              </div>
              <div class="message-content" style="font-style:italic; color:var(--text-muted);">message deleted</div>
              <div class="message-time"><%= msg.createdAt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' }) %></div>
            <% } else { %>
              <% if (!isSent) { %>
                <button class="message-action-btn" onclick="toggleReport('<%= msg.id %>')" title="Report message">&#9873;</button>
              <% } else { %>
                <button class="message-action-btn" onclick="deleteMessage('<%= msg.id %>')" title="Delete message">&#128465;</button>
              <% } %>
              <div class="message-sender-row">
                <% const sender = isSent ? currentUser : otherUser; %>
                <% if (sender.profileImagePath) { %>
                  <img src="<%= sender.profileImagePath %>" class="message-sender-avatar" alt="" onerror="this.style.display='none'">
                <% } else { %>
                  <div class="message-sender-avatar-fallback"><%= sender.username.charAt(0).toUpperCase() %></div>
                <% } %>
                <a href="/profile/<%= sender.username %>" class="message-sender-name user-hover-trigger" data-username="<%= sender.username %>" style="<%= getUsernameStyle(sender.role || 'user') %>; text-decoration:none;"><%= sender.username %></a>
              </div>
              <div class="message-content"><%= msg.content %></div>
              <div class="message-time"><%= msg.createdAt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' }) %></div>
              <% if (!isSent) { %>
                <div class="report-inline-form" id="report-<%= msg.id %>">
                  <form action="/messages/report/<%= msg.id %>" method="POST">
                    <textarea name="reason" maxlength="500" placeholder="Reason for reporting this message..." required></textarea>
                    <div class="report-actions">
                      <button type="button" class="report-cancel-btn" onclick="toggleReport('<%= msg.id %>')">Cancel</button>
                      <button type="submit" class="btn btn-danger btn-sm">Report</button>
                    </div>
                  </form>
                </div>
              <% } %>
            <% } %>
          </div>
        <% }); %>
      <% } else { %>
        <p class="empty-chat">No messages yet. Start the conversation below.</p>
      <% } %>
    </div>

    <!-- Compose Message -->
    <div class="compose-form">
      <form action="/messages/<%= otherUser.username %>" method="POST">
        <textarea name="content" id="msgTextarea" maxlength="1000" rows="3" placeholder="Type a message..." required></textarea>
        <div class="compose-footer">
          <span class="char-counter" id="msgCharCounter">0/1000</span>
          <button type="submit" class="btn btn-primary btn-sm">Send</button>
        </div>
      </form>
    </div>
  </div>

  <!-- ═══ Styled Confirm Modal ═══ -->
  <div class="confirm-modal-overlay" id="styledConfirmModal">
    <div class="confirm-modal-box">
      <h3 id="styledConfirmTitle">Confirm</h3>
      <p id="styledConfirmMessage" style="color:var(--text-secondary);margin-bottom:1rem;font-size:0.9rem;"></p>
      <div class="confirm-modal-actions">
        <button type="button" class="btn btn-secondary" onclick="closeStyledConfirm()">Cancel</button>
        <button type="button" class="btn btn-danger" id="styledConfirmYes">Confirm</button>
      </div>
    </div>
  </div>

  <%- include('../partials/auth-modals') %>
  <%- include('../partials/preloader') %>
  <%- include('../partials/footer') %>
  <script src="/js/auth.js"></script>
  <script src="/js/user-hover.js"></script>
  <script>
    // ── Styled Confirm Modal ──
    let _styledConfirmCb = null;
    function showStyledConfirm(message, onConfirm) {
      const modal = document.getElementById('styledConfirmModal');
      document.getElementById('styledConfirmMessage').textContent = message;
      _styledConfirmCb = onConfirm;
      modal.classList.add('active');
    }
    function closeStyledConfirm() {
      document.getElementById('styledConfirmModal').classList.remove('active');
      _styledConfirmCb = null;
    }
    document.getElementById('styledConfirmYes').addEventListener('click', () => {
      if (_styledConfirmCb) _styledConfirmCb();
      closeStyledConfirm();
    });
    document.getElementById('styledConfirmModal').addEventListener('click', function(e) {
      if (e.target === this) closeStyledConfirm();
    });
  </script>
  <script>
    // Auto-scroll to bottom of message list
    (function() {
      const list = document.getElementById('messageList');
      if (list) list.scrollTop = list.scrollHeight;
    })();

    // Character counter
    (function() {
      const ta = document.getElementById('msgTextarea');
      const counter = document.getElementById('msgCharCounter');
      if (ta && counter) {
        ta.addEventListener('input', function() {
          counter.textContent = ta.value.length + '/1000';
        });
      }
    })();

    // Toggle report form
    function toggleReport(msgId) {
      const form = document.getElementById('report-' + msgId);
      if (form) form.classList.toggle('open');
    }

    // Delete a sent message
    function deleteMessage(msgId) {
      showStyledConfirm('Delete this message? The other user will see "message deleted" in its place.', async () => {
        try {
          const resp = await fetch('/messages/delete/' + msgId, { method: 'POST' });
          const data = await resp.json();
          if (data.success) {
            const bubble = document.getElementById('msg-' + msgId);
            if (bubble) {
              bubble.classList.add('message-deleted');
              const content = bubble.querySelector('.message-content');
              if (content) {
                content.textContent = 'message deleted';
                content.style.fontStyle = 'italic';
                content.style.color = 'var(--text-muted)';
              }
              const actionBtn = bubble.querySelector('.message-action-btn');
              if (actionBtn) actionBtn.remove();
              const avatar = bubble.querySelector('.message-sender-avatar, .message-sender-avatar-fallback');
              if (avatar) avatar.remove();
            }
          } else {
            alert(data.error || 'Failed to delete message.');
          }
        } catch { alert('Network error.'); }
      });
    }
  </script>
</body>
</html>
