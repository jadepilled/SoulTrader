<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Messages | SoulTrader</title>
  <link rel="icon" type="image/png" href="/icons/favicon.png">
  <link href="https://fonts.googleapis.com/css2?family=Spectral:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/responsive.css">
  <style>
    .conversations-list {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      margin-top: 1rem;
    }
    .conversation-card {
      display: flex;
      align-items: center;
      gap: 0.85rem;
      padding: 0.85rem 1rem;
      background: rgba(18, 18, 18, 0.72);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: var(--radius);
      text-decoration: none;
      color: var(--text);
      transition: border-color 0.2s, background 0.2s;
    }
    .conversation-card:hover {
      border-color: rgba(255, 255, 255, 0.2);
      background: rgba(18, 18, 18, 0.85);
    }
    .conversation-avatar {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      object-fit: cover;
      flex-shrink: 0;
    }
    .conversation-avatar-fallback {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.08);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
      font-weight: 700;
      color: var(--text-muted);
      flex-shrink: 0;
    }
    .conversation-info {
      flex: 1;
      min-width: 0;
    }
    .conversation-top-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.5rem;
    }
    .conversation-username {
      font-weight: 700;
      font-size: 0.9rem;
    }
    .conversation-time {
      font-size: 0.72rem;
      color: var(--text-muted);
      white-space: nowrap;
    }
    .conversation-preview {
      font-size: 0.82rem;
      color: var(--text-muted);
      margin-top: 0.2rem;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .unread-badge {
      background: var(--primary, #c8a84e);
      color: #111;
      font-size: 0.68rem;
      font-weight: 700;
      padding: 0.15rem 0.45rem;
      border-radius: 999px;
      flex-shrink: 0;
      min-width: 1.2rem;
      text-align: center;
    }
    .empty-state {
      color: var(--text-muted);
      font-style: italic;
      margin-top: 2rem;
      text-align: center;
    }
    .new-message-bar {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 1rem;
      flex-wrap: wrap;
      align-items: center;
    }
    .new-message-bar input {
      flex: 1;
      min-width: 180px;
    }
    .thread-delete-btn {
      position: absolute;
      top: 50%;
      right: 0.75rem;
      transform: translateY(-50%);
      background: none;
      border: none;
      color: var(--text-muted);
      cursor: pointer;
      font-size: 0.75rem;
      opacity: 0;
      transition: opacity 0.2s, color 0.2s;
      padding: 0.3rem;
    }
    .conversation-card { position: relative; }
    .conversation-card:hover .thread-delete-btn { opacity: 1; }
    .thread-delete-btn:hover { color: var(--danger, #e74c3c); }
  </style>
</head>
<body>
  <%- include('../partials/navbar', { title: 'Messages', gameKey: '', pendingTradeCount: typeof pendingTradeCount !== 'undefined' ? pendingTradeCount : 0 }) %>

  <div class="main-content">
    <%- include('../partials/flash-messages') %>

    <% if (typeof query !== 'undefined' && query.error) { %>
      <div class="flash-message flash-error" style="margin-bottom:1rem;"><%= query.error %></div>
    <% } %>
    <% if (typeof query !== 'undefined' && query.success) { %>
      <div class="flash-message flash-success" style="margin-bottom:1rem;"><%= query.success %></div>
    <% } %>

    <div class="profile-section">
      <h2 class="profile-section-title">Messages</h2>

      <!-- New Message -->
      <div class="new-message-bar">
        <form action="/messages/new" method="GET" style="display:flex; gap:0.5rem; flex:1; min-width:200px;">
          <input type="text" name="to" placeholder="Message a user by username..." maxlength="50" required />
          <button type="submit" class="btn btn-primary btn-sm">Start Chat</button>
        </form>
      </div>

      <% if (typeof friends !== 'undefined' && friends.length > 0) { %>
        <div style="margin-bottom:1rem;">
          <span style="font-size:0.72rem; text-transform:uppercase; letter-spacing:0.5px; color:var(--text-muted);">Quick message a friend:</span>
          <div style="display:flex; flex-wrap:wrap; gap:0.4rem; margin-top:0.35rem;">
            <% friends.forEach(f => { %>
              <a href="/messages/<%= f.username %>" style="font-size:0.78rem; padding:0.2rem 0.6rem; background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:999px; text-decoration:none; color:var(--text-secondary); transition:border-color 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)'"><%= f.username %></a>
            <% }); %>
          </div>
        </div>
      <% } %>

      <% if (typeof conversations !== 'undefined' && conversations.length > 0) { %>
        <div class="conversations-list">
          <% conversations.forEach(conv => { %>
            <a href="/messages/<%= conv.otherUser.username %>" class="conversation-card">
              <% if (conv.otherUser.profileImagePath) { %>
                <img src="<%= conv.otherUser.profileImagePath %>" class="conversation-avatar" alt="" onerror="this.style.display='none'">
              <% } else { %>
                <div class="conversation-avatar-fallback"><%= conv.otherUser.username.charAt(0).toUpperCase() %></div>
              <% } %>
              <div class="conversation-info">
                <div class="conversation-top-row">
                  <span class="conversation-username" style="<%= getUsernameStyle(conv.otherUser.role || 'user') %>"><%= conv.otherUser.username %></span>
                  <span class="conversation-time"><%= conv.lastMessage.createdAt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %></span>
                </div>
                <div class="conversation-preview"><%= conv.lastMessage.content.length > 80 ? conv.lastMessage.content.substring(0, 80) + '...' : conv.lastMessage.content %></div>
              </div>
              <% if (conv.unreadCount && conv.unreadCount > 0) { %>
                <span class="unread-badge"><%= conv.unreadCount %></span>
              <% } %>
              <button type="button" class="thread-delete-btn" onclick="event.preventDefault(); event.stopPropagation(); deleteThread('<%= conv.otherUser.username %>', this);" title="Delete conversation">&#128465;</button>
            </a>
          <% }); %>
        </div>
      <% } else { %>
        <p class="empty-state">No messages yet.</p>
      <% } %>
    </div>
  </div>

  <!-- ═══ Styled Confirm Modal ═══ -->
  <div class="confirm-modal-overlay" id="styledConfirmModal">
    <div class="confirm-modal-box">
      <h3 id="styledConfirmTitle">Confirm</h3>
      <p id="styledConfirmMessage" style="color:var(--text-secondary);margin-bottom:1rem;font-size:0.9rem;"></p>
      <div class="confirm-modal-actions">
        <button type="button" class="btn btn-secondary" onclick="closeStyledConfirm()">Cancel</button>
        <button type="button" class="btn btn-danger" id="styledConfirmYes">Confirm</button>
      </div>
    </div>
  </div>

  <%- include('../partials/auth-modals') %>
  <%- include('../partials/preloader') %>
  <%- include('../partials/footer') %>
  <script src="/js/auth.js"></script>
  <script>
    let _styledConfirmCb = null;
    function showStyledConfirm(message, onConfirm) {
      const modal = document.getElementById('styledConfirmModal');
      document.getElementById('styledConfirmMessage').textContent = message;
      _styledConfirmCb = onConfirm;
      modal.classList.add('active');
    }
    function closeStyledConfirm() {
      document.getElementById('styledConfirmModal').classList.remove('active');
      _styledConfirmCb = null;
    }
    document.getElementById('styledConfirmYes').addEventListener('click', () => {
      if (_styledConfirmCb) _styledConfirmCb();
      closeStyledConfirm();
    });
    document.getElementById('styledConfirmModal').addEventListener('click', function(e) {
      if (e.target === this) closeStyledConfirm();
    });

    function deleteThread(username, btn) {
      showStyledConfirm('Delete this entire conversation with ' + username + '? This cannot be undone.', async () => {
        try {
          const resp = await fetch('/messages/delete-thread/' + username, { method: 'POST' });
          const data = await resp.json();
          if (data.success) {
            const card = btn.closest('.conversation-card');
            if (card) card.remove();
          } else {
            alert(data.error || 'Failed to delete thread.');
          }
        } catch { alert('Network error.'); }
      });
    }
  </script>
</body>
</html>
