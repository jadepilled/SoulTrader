<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | SoulTrader</title>
  <link rel="icon" type="image/x-icon" href="/icons/favicon.ico">
  <link href="https://fonts.googleapis.com/css2?family=Spectral:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/responsive.css">
  <style>
    :root {
      --game-accent: <%= accentColor %>;
      --game-accent-rgb: <%= accentColorRgb %>;
      --game-secondary: <%= secondaryColor %>;
      --game-secondary-rgb: <%= secondaryColorRgb %>;
    }

    /* ── Trade creation modal — wider for item builder ── */
    #create-offer-modal .modal-content { max-width: 680px; }

    /* ── Item search row ── */
    .item-search-row { position: relative; margin-bottom: 0.25rem; }
    .item-search-row input { padding-right: 2rem; }

    /* ── Item grid ── */
    .item-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      min-height: 60px;
      padding: 0.5rem;
      background: var(--bg-primary);
      border: 1px dashed var(--border-color);
      border-radius: var(--radius);
      margin-bottom: 0.75rem;
    }
    .item-grid-empty {
      width: 100%;
      text-align: center;
      color: var(--text-muted);
      font-size: 0.8rem;
      padding: 0.75rem 0;
      pointer-events: none;
    }

    /* ── Item box (in creation grid) ── */
    .item-box {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      background: var(--bg-tertiary);
      border: 1px solid var(--border-color);
      border-radius: var(--radius);
      padding: 6px 8px 6px;
      position: relative;
      min-width: 80px;
      max-width: 100px;
      font-size: 0.75rem;
      transition: border-color var(--transition);
    }
    .item-box:hover { border-color: var(--accent); }

    .item-box-icon { width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; }
    .item-box-icon img { width: 40px; height: 40px; object-fit: contain; border-radius: 4px; }
    .item-icon-fallback {
      width: 40px; height: 40px;
      display: flex; align-items: center; justify-content: center;
      background: var(--bg-card); border-radius: 4px;
      font-size: 1.1rem; font-weight: 700; color: var(--accent);
    }

    .item-box-name {
      text-align: center; font-size: 0.7rem; line-height: 1.2;
      color: var(--text-primary); max-width: 84px;
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }

    /* Qty controls */
    .item-box-qty {
      display: flex; align-items: center; gap: 4px;
    }
    .qty-btn {
      width: 20px; height: 20px;
      background: var(--bg-card); border: 1px solid var(--border-color);
      border-radius: 4px; cursor: pointer; color: var(--text-primary);
      font-size: 0.8rem; line-height: 1; display: flex; align-items: center; justify-content: center;
      transition: background var(--transition);
    }
    .qty-btn:hover { background: var(--accent); border-color: var(--accent); color: #fff; }
    .item-qty-value {
      font-size: 0.8rem; font-weight: 700; min-width: 16px; text-align: center;
    }

    /* Upgrade select */
    .item-box-upgrade select {
      font-size: 0.7rem; padding: 2px 4px; width: 54px;
      background: var(--bg-input); border: 1px solid var(--border-color);
      border-radius: 4px; color: var(--text-primary);
    }

    /* Remove button */
    .item-box-remove {
      position: absolute; top: -6px; right: -6px;
      width: 18px; height: 18px; border-radius: 50%;
      background: var(--danger); border: none; color: #fff;
      font-size: 12px; cursor: pointer; line-height: 1;
      display: flex; align-items: center; justify-content: center;
      opacity: 0; transition: opacity var(--transition);
    }
    .item-box:hover .item-box-remove { opacity: 1; }

    /* ── Dropdown ── */
    .dropdown { position: absolute; top: 100%; left: 0; right: 0; z-index: 4000; }
    .dropdown-item {
      display: flex; align-items: center; gap: 8px;
      padding: 0.4rem 0.6rem; cursor: pointer; font-size: 0.85rem;
      transition: background var(--transition);
    }
    .dropdown-item:hover { background: var(--bg-tertiary); }
    .dropdown-item-icon { width: 22px; height: 22px; object-fit: contain; border-radius: 3px; flex-shrink: 0; }
    .dropdown-item-type {
      margin-left: auto; font-size: 0.7rem; color: var(--text-muted);
      text-transform: capitalize; flex-shrink: 0;
    }

    /* ── Trade preview (inside modal) ── */
    .trade-preview {
      display: grid; grid-template-columns: 1fr auto 1fr;
      gap: 0.5rem; align-items: start;
      background: var(--bg-primary); border: 1px solid var(--border-subtle);
      border-radius: var(--radius); padding: 0.75rem; margin-bottom: 0.75rem;
    }
    .preview-side { display: flex; flex-direction: column; gap: 4px; }
    .preview-side-label {
      font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px;
      color: var(--text-muted); margin-bottom: 4px; text-align: center;
    }
    .preview-arrow {
      align-self: center; font-size: 1.4rem; color: var(--text-muted);
    }
    .preview-item-row { display: flex; align-items: center; gap: 6px; }
    .preview-item-icon { width: 22px; height: 22px; object-fit: contain; border-radius: 3px; }
    .preview-item-label { font-size: 0.78rem; color: var(--text-primary); }
    .preview-empty { font-size: 0.78rem; color: var(--text-muted); font-style: italic; }

    /* ── Trade cards — item display ── */
    .trade-item-row {
      display: flex; align-items: center; gap: 6px;
      padding: 3px 0; font-size: 0.82rem;
    }
    .trade-item-icon { width: 24px; height: 24px; object-fit: contain; border-radius: 3px; flex-shrink: 0; }
    .trade-item-icon-fallback {
      width: 24px; height: 24px; border-radius: 3px;
      background: var(--bg-tertiary); display: flex; align-items: center;
      justify-content: center; font-size: 0.65rem; font-weight: 700;
      color: var(--accent); flex-shrink: 0;
    }
    .trade-item-name { flex: 1; color: var(--text-primary); }
    .trade-item-meta { font-size: 0.72rem; color: var(--text-muted); white-space: nowrap; }
  </style>
</head>
<body>
  <%- include('partials/navbar', { pendingTradeCount: typeof pendingTradeCount !== 'undefined' ? pendingTradeCount : 0 }) %>

  <div class="main-content">
    <!-- Game Logo -->
    <div class="header-logo">
      <img src="<%= logoUrl %>" alt="<%= title %>" />
    </div>

    <%- include('partials/flash-messages') %>

    <!-- ═══ Trade Creation Modal ═══ -->
    <div id="create-offer-modal" class="modal-overlay">
      <div class="modal-content">
        <button class="close-btn">&times;</button>
        <h2>Create Trade Offer</h2>
        <form id="create-offer-form" action="/trade/create" method="POST">
          <input type="hidden" name="game"  value="<%= gameKey %>" />
          <input type="hidden" id="gameKeyInput" value="<%= gameKey %>" />
          <input type="hidden" id="hiddenOfferedItems"   name="offeredItems"   value="" />
          <input type="hidden" id="hiddenRequestedItems" name="requestedItems" value="" />

          <!-- Live preview -->
          <div class="trade-preview">
            <div class="preview-side">
              <div class="preview-side-label">You Offer</div>
              <div id="preview-offered"><span class="preview-empty">None yet</span></div>
            </div>
            <div class="preview-arrow">⇄</div>
            <div class="preview-side">
              <div class="preview-side-label">You Want</div>
              <div id="preview-requested"><span class="preview-empty">None yet</span></div>
            </div>
          </div>

          <!-- Offered items -->
          <label>Items You Are Offering</label>
          <div class="item-search-row">
            <input type="text" id="offeredItemInput" placeholder="Search items…" autocomplete="off" />
            <ul id="offeredItemDropdown" class="dropdown"></ul>
          </div>
          <div id="offeredItemsGrid" class="item-grid">
            <span class="item-grid-empty">Search above to add items</span>
          </div>

          <!-- Requested items -->
          <label>Items You Are Requesting</label>
          <div class="item-search-row">
            <input type="text" id="requestedItemInput" placeholder="Search items…" autocomplete="off" />
            <ul id="requestedItemDropdown" class="dropdown"></ul>
          </div>
          <div id="requestedItemsGrid" class="item-grid">
            <span class="item-grid-empty">Search above to add items</span>
          </div>

          <!-- Platform & notes -->
          <label for="platform">Platform</label>
          <select id="platform" name="platform" required>
            <option value="" disabled selected>Select platform</option>
            <option value="PlayStation">PlayStation</option>
            <option value="Xbox">Xbox</option>
            <option value="PC">PC</option>
          </select>

          <label for="characterLevel">Character Level <span style="color:var(--text-muted);font-size:0.8rem;">(optional)</span></label>
          <input type="number" id="characterLevel" name="characterLevel" min="1" max="999" placeholder="e.g. 120" style="width:120px;" />

          <label for="additionalNotes">Additional Notes <span style="color:var(--text-muted);font-size:0.8rem;">(optional)</span></label>
          <textarea id="additionalNotes" name="additionalNotes" placeholder="Meeting point, character level, timezone…"></textarea>

          <button type="submit" class="btn btn-success btn-full" style="margin-top:1rem;">Post Trade Offer</button>
        </form>
      </div>
    </div>

    <!-- ═══ Accept Trade Modal ═══ -->
    <div id="acceptTradeModal" class="modal-overlay">
      <div class="modal-content">
        <button class="close-btn" onclick="closeAcceptModal()">&times;</button>
        <h2>Accept Trade Offer</h2>
        <form id="acceptTradeForm">
          <input type="hidden" id="tradeId" name="tradeId" />
          <label for="meetingPoint">Preferred Meeting Point</label>
          <input type="text" id="meetingPoint" name="meetingPoint" placeholder="e.g. Firelink Shrine" />
          <label for="discordName">Discord Name <span style="color:var(--danger);">*</span></label>
          <input type="text" id="discordName" name="discordName" required placeholder="username or username#0000" />
          <label for="inGameName">In-Game Character Name</label>
          <input type="text" id="inGameName" name="inGameName" placeholder="Your character name" />
          <label for="additionalInfo">Additional Information</label>
          <textarea id="additionalInfo" name="additionalInfo" placeholder="Timezone, availability…"></textarea>
          <button type="submit" class="btn btn-success btn-full" style="margin-top:1rem;">Continue</button>
        </form>
      </div>
    </div>

    <!-- ═══ Confirmation Modal ═══ -->
    <div id="confirmationModal" class="modal-overlay">
      <div class="modal-content">
        <button class="close-btn" onclick="closeConfirmationModal()">&times;</button>
        <h2>Confirm Trade</h2>
        <div id="tradeDetails" style="margin-bottom:1rem;color:var(--text-secondary);font-size:0.9rem;line-height:1.6;"></div>
        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;font-size:0.9rem;">
          <input type="checkbox" id="confirmationCheckbox" />
          <span>I confirm I have these items and am willing to trade them.</span>
        </label>
        <button id="finalSubmitButton" class="btn btn-success btn-full" style="margin-top:1rem;" disabled>Accept Trade</button>
      </div>
    </div>

    <!-- ═══ Filter Bar ═══ -->
    <section>
      <div class="filter-bar">
        <% if (userId) { %>
          <button id="create-offer-btn" class="btn btn-primary">+ Create Trade Offer</button>
        <% } %>
        <div class="filter-group">
          <label for="platformSelect">Platform</label>
          <select id="platformSelect">
            <option value="all">All</option>
            <option value="PC">PC</option>
            <option value="PlayStation">PlayStation</option>
            <option value="Xbox">Xbox</option>
          </select>
        </div>
        <div class="filter-group">
          <label for="sortSelect">Sort</label>
          <select id="sortSelect">
            <option value="desc" selected>Newest First</option>
            <option value="asc">Oldest First</option>
          </select>
        </div>
        <div class="filter-group">
          <label for="searchInput">Search</label>
          <input type="text" id="searchInput" placeholder="Item name…" style="min-width:150px;" />
        </div>
      </div>

      <% if (!offers || offers.length === 0) { %>
        <div class="no-offers-card">No trade offers yet. Be the first to create one!</div>
      <% } else { %>
        <div class="offers-grid" id="offers-grid">
          <% offers.forEach(offer => {
            // offeredItems / requestedItems are already parsed arrays via the Trade model getter
            const offItems = Array.isArray(offer.offeredItems)  ? offer.offeredItems  : [];
            const reqItems = Array.isArray(offer.requestedItems) ? offer.requestedItems : [];
            const now  = new Date();
            const diff = now - offer.createdAt;
            const mins = Math.floor(diff / 60000);
            let timeStr;
            if (mins < 1)    timeStr = 'just now';
            else if (mins < 60)   timeStr = mins + 'm ago';
            else if (mins < 1440) timeStr = Math.floor(mins / 60) + 'h ago';
            else             timeStr = Math.floor(mins / 1440) + 'd ago';
          %>
            <div class="trade-card"
                 data-platform="<%= offer.platform %>"
                 data-created-at="<%= offer.createdAt.getTime() %>">

              <div class="trade-card-banner"><%= offer.game %></div>

              <div class="offer-heading">
                Offer from
                <span class="tooltip" tabindex="0" style="<%= getUsernameStyle(offer.offerCreator.role) %>">
                  <a href="/profile/<%= offer.offerCreator.username %>" style="color:inherit; text-decoration:none;">
                    <%= offer.offerCreator.username %>
                  </a>
                  <span class="tooltiptext">
                    Karma: <%= offer.offerCreator.positiveKarma - offer.offerCreator.negativeKarma %><br>
                    Role: <%= offer.offerCreator.role %>
                  </span>
                </span>
                <span class="time-ago"><%= timeStr %></span>
              </div>

              <div class="trade-card-inner">
                <div class="offered-col">
                  <h2>Offers</h2>
                  <% offItems.forEach(item => {
                    const metaParts = [];
                    if (item.qty > 1) metaParts.push('×' + item.qty);
                    if (item.upgrade !== null && item.upgrade !== undefined) metaParts.push('+' + item.upgrade);
                    const meta = metaParts.join(' ');
                  %>
                    <div class="trade-item-row">
                      <% if (item.iconPath) { %>
                        <img class="trade-item-icon" src="<%= item.iconPath %>" alt="" onerror="this.style.display='none'">
                      <% } else { %>
                        <div class="trade-item-icon-fallback"><%= item.name.charAt(0) %></div>
                      <% } %>
                      <span class="trade-item-name"><%= item.name %></span>
                      <% if (meta) { %><span class="trade-item-meta"><%= meta %></span><% } %>
                    </div>
                  <% }); %>
                </div>
                <div class="requested-col">
                  <h2>Wants</h2>
                  <% reqItems.forEach(item => {
                    const metaParts = [];
                    if (item.qty > 1) metaParts.push('×' + item.qty);
                    if (item.upgrade !== null && item.upgrade !== undefined) metaParts.push('+' + item.upgrade);
                    const meta = metaParts.join(' ');
                  %>
                    <div class="trade-item-row">
                      <% if (item.iconPath) { %>
                        <img class="trade-item-icon" src="<%= item.iconPath %>" alt="" onerror="this.style.display='none'">
                      <% } else { %>
                        <div class="trade-item-icon-fallback"><%= item.name.charAt(0) %></div>
                      <% } %>
                      <span class="trade-item-name"><%= item.name %></span>
                      <% if (meta) { %><span class="trade-item-meta"><%= meta %></span><% } %>
                    </div>
                  <% }); %>
                </div>
              </div>

              <div class="trade-details">
                <div class="platform">Platform: <%= offer.platform %></div>
                <% if (offer.characterLevel) { %>
                  <span class="char-level-badge">LVL <%= offer.characterLevel %></span>
                <% } %>
                <% if (offer.additionalNotes) { %>
                  <div class="notes">Notes: <%= offer.additionalNotes %></div>
                <% } %>
              </div>

              <div class="trade-actions">
                <% if (userId && userId !== offer.offerCreatorId) { %>
                  <button class="btn btn-success btn-accept" data-trade-id="<%= offer.id %>">Accept</button>
                <% } %>
                <% if (userId && (userId === offer.offerCreatorId || role === 'admin')) { %>
                  <form action="/trade/rescind/<%= offer.id %>" method="POST" style="flex:1;" onsubmit="return confirm('Cancel this trade offer?')">
                    <button type="submit" class="btn btn-danger btn-full">Cancel</button>
                  </form>
                <% } %>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
    </section>
  </div>

  <%- include('partials/auth-modals') %>
  <%- include('partials/footer') %>
  <script src="/js/auth.js"></script>
  <script src="/js/trade.js"></script>
</body>
</html>
