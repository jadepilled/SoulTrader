<nav class="navbar">
  <div class="brand">
    <a href="/">SoulTrader</a>
  </div>

  <div class="nav-links">
    <% if (typeof gameConfigs !== 'undefined') { %>
      <% Object.entries(gameConfigs).forEach(([key, cfg]) => { %>
        <a href="/<%= key %>" class="<%= typeof gameKey !== 'undefined' && gameKey === key ? 'nav-active' : '' %>"><%= cfg.title.replace(/:.+/, '').trim() %></a>
      <% }); %>
    <% } %>
    <a href="/items" class="<%= typeof activeNav !== 'undefined' && activeNav === 'items' ? 'nav-active' : '' %>">Item DB</a>
  </div>

  <div class="nav-user">
    <% if (typeof userId !== 'undefined' && userId) { %>
      <a href="/trade/my-trades" class="nav-trades-link">
        My Trades
        <% if (typeof pendingTradeCount !== 'undefined' && pendingTradeCount > 0) { %>
          <span class="nav-trade-badge"><%= pendingTradeCount %></span>
        <% } %>
      </a>
      <a href="/profile">Profile</a>
      <a href="/feedback">Feedback</a>
      <% if (typeof role !== 'undefined' && role === 'admin') { %>
        <a href="/admin" style="color: #fa9cff;">Admin</a>
      <% } %>
      <a href="/auth/logout">Log Out</a>
    <% } else { %>
      <a href="#" id="openSignupLink">Sign Up</a>
      <a href="#" id="openLoginLink">Log In</a>
    <% } %>
  </div>
</nav>

<!-- Alpha Disclaimer Banner -->
<div class="alpha-banner" id="alphaBanner">
  <span>SoulTrader is currently in alpha. Features may change and bugs may occur. <a href="/feedback">Report issues</a></span>
  <button class="alpha-banner-close" onclick="document.getElementById('alphaBanner').style.display='none'">&times;</button>
</div>
