<nav class="navbar">
  <div class="brand">
    <a href="/"><%= typeof title !== 'undefined' ? `SoulTrader | ${title}` : 'SoulTrader' %></a>
  </div>

  <button class="hamburger" id="hamburgerBtn" aria-label="Menu">&#9776;</button>

  <div class="nav-links" id="navLinks">
    <% if (typeof gameConfigs !== 'undefined') { %>
      <% Object.entries(gameConfigs).forEach(([key, cfg]) => { %>
        <a href="/<%= key %>" class="<%= typeof gameKey !== 'undefined' && gameKey === key ? 'nav-active' : '' %>"><%= cfg.title.replace(/:.+/, '').trim() %></a>
      <% }); %>
    <% } %>

    <div class="nav-user">
      <% if (typeof userId !== 'undefined' && userId) { %>
        <a href="/trade/my-trades" style="font-weight:600;">My Trades</a>
        <a href="/profile" style="font-weight:600;">Profile</a>
        <% if (typeof role !== 'undefined' && role === 'admin') { %>
          <a href="/admin" style="font-weight:600; color: #fa9cff;">Admin</a>
        <% } %>
        <span class="tooltip" tabindex="0" style="<%= typeof usernameStyle !== 'undefined' ? usernameStyle : '' %>">
          <%= typeof username !== 'undefined' ? username : '' %>
          <span class="tooltiptext">
            Karma: <%= typeof karma !== 'undefined' ? karma : 0 %><br>
            Role: <%= typeof role !== 'undefined' ? role : 'user' %>
          </span>
        </span>
        <a href="/auth/logout" style="font-weight:600;">Log Out</a>
      <% } else { %>
        <a href="#" id="openSignupLink" style="font-weight:600;">Sign Up</a>
        <a href="#" id="openLoginLink" style="font-weight:600;">Log In</a>
      <% } %>
    </div>
  </div>
</nav>
