<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Trades | SoulTrader</title>
  <link rel="icon" type="image/png" href="/icons/favicon.png">
  <link href="https://fonts.googleapis.com/css2?family=Spectral:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/responsive.css">
  <style>
    .trade-info-section {
      margin-top: 0.75rem;
      padding: 0.75rem;
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: var(--radius);
    }
    .trade-info-section h3 {
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--text-muted);
      margin-bottom: 0.5rem;
    }
    .trade-info-row {
      display: flex;
      gap: 0.5rem;
      font-size: 0.82rem;
      padding: 0.2rem 0;
    }
    .trade-info-label {
      color: var(--text-muted);
      min-width: 100px;
      flex-shrink: 0;
    }
    .trade-info-value {
      color: var(--text-primary);
      word-break: break-word;
    }
    .trade-contact-section {
      margin-top: 0.5rem;
      padding: 0.5rem 0.75rem;
      background: rgba(var(--accent-rgb, 138,138,138), 0.06);
      border: 1px solid rgba(var(--accent-rgb, 138,138,138), 0.12);
      border-radius: var(--radius);
    }
    .trade-contact-section h4 {
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--text-muted);
      margin-bottom: 0.35rem;
    }
    /* Rating form */
    .rating-form {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .rating-form .rating-row {
      display: flex;
      gap: 0.5rem;
      align-items: center;
    }
    .rating-form textarea {
      width: 100%;
      padding: 0.4rem 0.6rem;
      background: var(--bg-input);
      border: 1px solid var(--border-color);
      border-radius: var(--radius);
      color: var(--text-primary);
      font-family: var(--font);
      font-size: 0.82rem;
      resize: vertical;
      min-height: 50px;
    }
    /* Feedback display */
    .trade-feedback-block {
      margin-top: 0.5rem;
      padding: 0.5rem 0.75rem;
      background: rgba(34, 197, 94, 0.05);
      border-left: 3px solid var(--success);
      border-radius: 0 var(--radius) var(--radius) 0;
      font-size: 0.82rem;
    }
    .trade-feedback-block.negative {
      background: rgba(239, 68, 68, 0.05);
      border-left-color: var(--danger);
    }
    .trade-feedback-label {
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--text-muted);
      margin-bottom: 0.2rem;
    }
  </style>
</head>
<body>
  <%- include('partials/navbar', { title: 'My Trades', gameKey: '', pendingTradeCount: typeof pendingTradeCount !== 'undefined' ? pendingTradeCount : 0 }) %>
  <%- include('partials/flash-messages') %>

  <div class="main-content">
    <h1 class="section-title" style="margin-top:0.5rem;">My Trades</h1>

    <%
      const gameColorMap = {
        'Dark Souls':    { color: '#7b86a2', rgb: '123, 134, 162' },
        'Dark Souls 2':  { color: '#8b7eaa', rgb: '139, 126, 170' },
        'Dark Souls 3':  { color: '#6e7fa0', rgb: '110, 127, 160' },
        'Elden Ring':    { color: '#c8a84e', rgb: '200, 168, 78' },
        "Demon's Souls": { color: '#8a8a8a', rgb: '138, 138, 138' },
      };

      function getGameBannerStyle(gameName) {
        const gc = gameColorMap[gameName] || { color: '#8a8a8a', rgb: '138, 138, 138' };
        return `background: rgba(${gc.rgb}, 0.2); color: ${gc.color}; border-bottom: 1px solid rgba(${gc.rgb}, 0.3);`;
      }

      function getStatusBadge(trade) {
        const s = trade.status;
        if (s === 'open') {
          const offerCount = trade.tradeOffers ? trade.tradeOffers.filter(o => o.status === 'pending').length : 0;
          if (offerCount > 0) {
            return '<span class="status-badge status-awaiting">' + offerCount + ' Offer' + (offerCount !== 1 ? 's' : '') + ' Received</span>';
          }
          return '<span class="status-badge status-open">Open</span>';
        }
        if (s === 'awaiting_confirmation') {
          let detail = '';
          if (trade.creatorConfirmed && !trade.acceptorConfirmed) detail = ' (Creator confirmed)';
          else if (!trade.creatorConfirmed && trade.acceptorConfirmed) detail = ' (Acceptor confirmed)';
          else detail = ' (Awaiting both)';
          return '<span class="status-badge status-awaiting">Awaiting Confirmation' + detail + '</span>';
        }
        if (s === 'completed') return '<span class="status-badge status-completed">Completed</span>';
        if (s === 'declined') return '<span class="status-badge status-declined">Declined</span>';
        if (s === 'cancelled') return '<span class="status-badge status-cancelled">Cancelled</span>';
        if (s === 'expired') return '<span class="status-badge status-declined">Expired</span>';
        return '<span class="status-badge">' + s + '</span>';
      }

      function getTimeAgo(createdAt) {
        const now  = new Date();
        const diff = now - createdAt;
        const mins = Math.floor(diff / 60000);
        if (mins < 1)    return 'just now';
        if (mins < 60)   return mins + 'm ago';
        if (mins < 1440) return Math.floor(mins / 60) + 'h ago';
        return Math.floor(mins / 1440) + 'd ago';
      }

      // Parse UTC offset from timezone string like "UTC+10:00 (Sydney/Melbourne)"
      function parseUtcOffset(tzStr) {
        if (!tzStr) return null;
        const m = tzStr.match(/UTC([+-])(\d{1,2}):(\d{2})/);
        if (!m) return null;
        const sign = m[1] === '+' ? 1 : -1;
        return sign * (parseInt(m[2], 10) * 60 + parseInt(m[3], 10));
      }

      // Helper to render trade party details
      function renderTradeDetails(trade, partyType, viewerTz) {
        // partyType: 'creator' or 'acceptor'
        const prefix = partyType;
        const ign = trade[prefix + 'InGameName'];
        const meeting = trade[prefix + 'MeetingPoint'];
        const info = trade[prefix + 'AdditionalInfo'];
        // Get timezone from the user object
        const userObj = partyType === 'creator' ? trade.offerCreator : trade.acceptor;
        const tz = userObj ? userObj.timezone : null;
        if (!ign && !meeting && !info && !tz) return '';

        let html = '<div class="trade-info-section"><h3>' + (partyType === 'creator' ? "Creator's" : "Acceptor's") + ' Details</h3>';
        if (ign)     html += '<div class="trade-info-row"><span class="trade-info-label">In-Game Name</span><span class="trade-info-value">' + ign + '</span></div>';
        if (meeting) html += '<div class="trade-info-row"><span class="trade-info-label">Meeting Point</span><span class="trade-info-value">' + meeting + '</span></div>';

        // Timezone — show their current time and difference from viewer
        if (tz) {
          const theirOffset = parseUtcOffset(tz);
          const viewerOffset = viewerTz ? parseUtcOffset(viewerTz) : null;
          if (theirOffset !== null) {
            const now = new Date();
            const utcMs = now.getTime() + now.getTimezoneOffset() * 60000;
            const theirTime = new Date(utcMs + theirOffset * 60000);
            const h = theirTime.getHours();
            const m = theirTime.getMinutes();
            const ampm = h >= 12 ? 'PM' : 'AM';
            const h12 = h % 12 || 12;
            const timeStr = h12 + ':' + String(m).padStart(2, '0') + ' ' + ampm;

            let diffStr = '';
            if (viewerOffset !== null && viewerOffset !== theirOffset) {
              const diffMins = theirOffset - viewerOffset;
              const diffH = Math.floor(Math.abs(diffMins) / 60);
              const diffM = Math.abs(diffMins) % 60;
              const sign = diffMins > 0 ? '+' : '-';
              diffStr = ' (' + sign + diffH + (diffM ? ':' + String(diffM).padStart(2, '0') : '') + 'h from you)';
            }

            html += '<div class="trade-info-row"><span class="trade-info-label">Their Time</span><span class="trade-info-value">' + timeStr + diffStr + '</span></div>';
          } else {
            html += '<div class="trade-info-row"><span class="trade-info-label">Timezone</span><span class="trade-info-value">' + tz + '</span></div>';
          }
        }

        if (info)    html += '<div class="trade-info-row"><span class="trade-info-label">Additional Info</span><span class="trade-info-value">' + info + '</span></div>';
        html += '</div>';
        return html;
      }

      // Get viewer's timezone for offset calculations
      const viewerUser = typeof currentUser !== 'undefined' && currentUser ? currentUser : null;
      const viewerTimezone = viewerUser ? viewerUser.timezone : null;

      // Helper to render connected contact info for a user
      function renderContactInfo(user, label) {
        if (!user) return '';
        const c = [];
        if (user.contactDiscord) c.push('<div class="trade-info-row"><span class="trade-info-label">Discord</span><span class="trade-info-value">' + user.contactDiscord + '</span></div>');
        if (user.contactSteam)   c.push('<div class="trade-info-row"><span class="trade-info-label">Steam</span><span class="trade-info-value">' + user.contactSteam + '</span></div>');
        if (user.contactPSN)     c.push('<div class="trade-info-row"><span class="trade-info-label">PSN</span><span class="trade-info-value">' + user.contactPSN + '</span></div>');
        if (user.contactXbox)    c.push('<div class="trade-info-row"><span class="trade-info-label">Xbox</span><span class="trade-info-value">' + user.contactXbox + '</span></div>');
        if (c.length === 0) return '';
        return '<div class="trade-contact-section"><h4>' + label + ' Contact Info</h4>' + c.join('') + '</div>';
      }
    %>

    <!-- ---- Trades I Created ---- -->
    <h2 style="margin:2rem 0 1rem;">Trades I Created</h2>
    <% if (!createdTrades || createdTrades.length === 0) { %>
      <div class="no-offers-card">No trades created yet.</div>
    <% } else { %>
      <div class="offers-grid">
        <% createdTrades.forEach(trade => {
          const offItems = Array.isArray(trade.offeredItems)    ? trade.offeredItems    : [];
          const reqItems = Array.isArray(trade.requestedItems)  ? trade.requestedItems  : [];
        %>
          <div class="trade-card">
            <% if (trade.game) { %>
              <div class="trade-card-banner" style="<%- getGameBannerStyle(trade.game) %>"><%= trade.gameVariant || trade.game %></div>
            <% } %>
            <div class="trade-card-platform-banner"><%= trade.platform %></div>
            <div class="offer-heading">
              <% if (trade.characterLevel) { %>
                <span class="char-level-badge">LVL <%= trade.characterLevel %></span>
              <% } %>
              <span class="time-ago"><%= getTimeAgo(trade.createdAt) %></span>
              <div style="margin-top:0.5rem;"><%- getStatusBadge(trade) %></div>
            </div>

            <div class="trade-card-inner">
              <div class="offered-col">
                <h2>Offered</h2>
                <% offItems.forEach(item => {
                  const metaParts = [];
                  const _mq = fmtQty(item.qty); if (_mq) metaParts.push('\u00d7' + _mq);
                  if (item.upgrade !== null && item.upgrade !== undefined) metaParts.push('+' + item.upgrade);
                  const meta = metaParts.join(' ');
                %>
                  <div class="trade-item-row">
                    <% if (item.iconPath) { %>
                      <img class="trade-item-icon" src="<%= item.iconPath %>" alt="" onerror="this.style.display='none'">
                    <% } else { %>
                      <div class="trade-item-icon-fallback"><%= item.name.charAt(0) %></div>
                    <% } %>
                    <span class="trade-item-name"><%= item.name %></span>
                    <% if (meta) { %><span class="trade-item-meta"><%= meta %></span><% } %>
                  </div>
                <% }); %>
              </div>
              <div class="requested-col">
                <h2>Requested</h2>
                <% reqItems.forEach(item => {
                  const metaParts = [];
                  const _mq = fmtQty(item.qty); if (_mq) metaParts.push('\u00d7' + _mq);
                  if (item.upgrade !== null && item.upgrade !== undefined) metaParts.push('+' + item.upgrade);
                  const meta = metaParts.join(' ');
                %>
                  <div class="trade-item-row">
                    <% if (item.iconPath) { %>
                      <img class="trade-item-icon" src="<%= item.iconPath %>" alt="" onerror="this.style.display='none'">
                    <% } else { %>
                      <div class="trade-item-icon-fallback"><%= item.name.charAt(0) %></div>
                    <% } %>
                    <span class="trade-item-name"><%= item.name %></span>
                    <% if (meta) { %><span class="trade-item-meta"><%= meta %></span><% } %>
                  </div>
                <% }); %>
              </div>
            </div>

            <!-- Acceptor info / Trade Offers -->
            <div class="trade-details">
              <% if (trade.acceptor) { %>
                <p style="font-size:0.85rem; margin:0.5rem 0;">
                  Accepted by:
                  <span class="user-hover-trigger"
                        data-username="<%= trade.acceptor.username %>"
                        style="<%= getUsernameStyle(trade.acceptor.role) %>">
                    <a href="/profile/<%= trade.acceptor.username %>" style="color:inherit;"><%= trade.acceptor.username %></a>
                  </span>
                </p>
              <% } %>

              <!-- Pending trade offers (multi-offer system) -->
              <% if (trade.status === 'open' && trade.tradeOffers && trade.tradeOffers.length > 0) { %>
                <%
                  const pendingOffs = trade.tradeOffers.filter(o => o.status === 'pending');
                %>
                <% if (pendingOffs.length > 0) { %>
                  <div class="trade-info-section">
                    <h3>Incoming Offers (<%= pendingOffs.length %>)</h3>
                    <% pendingOffs.forEach(off => { %>
                      <div style="padding:0.5rem;margin-bottom:0.5rem;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:var(--radius);">
                        <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.35rem;">
                          <span class="user-hover-trigger" data-username="<%= off.offerer ? off.offerer.username : 'Unknown' %>"
                                style="<%= off.offerer ? getUsernameStyle(off.offerer.role) : '' %>; font-weight:700;">
                            <a href="/profile/<%= off.offerer ? off.offerer.username : '' %>" style="color:inherit;"><%= off.offerer ? off.offerer.username : 'Unknown' %></a>
                          </span>
                          <span style="font-size:0.72rem;color:var(--text-muted);"><%= getTimeAgo(off.createdAt) %></span>
                        </div>
                        <% if (off.inGameName) { %>
                          <div class="trade-info-row"><span class="trade-info-label">Character</span><span class="trade-info-value"><%= off.inGameName %></span></div>
                        <% } %>
                        <% if (off.meetingPoint) { %>
                          <div class="trade-info-row"><span class="trade-info-label">Meeting Point</span><span class="trade-info-value"><%= off.meetingPoint %></span></div>
                        <% } %>
                        <% if (off.offerer && off.offerer.timezone) { %>
                          <%
                            const _offOffset = parseUtcOffset(off.offerer.timezone);
                            const _viewOffset = viewerTimezone ? parseUtcOffset(viewerTimezone) : null;
                            let _tzDisplay = off.offerer.timezone;
                            if (_offOffset !== null) {
                              const _n = new Date();
                              const _utcMs = _n.getTime() + _n.getTimezoneOffset() * 60000;
                              const _tTime = new Date(_utcMs + _offOffset * 60000);
                              const _h = _tTime.getHours();
                              const _m = _tTime.getMinutes();
                              const _ap = _h >= 12 ? 'PM' : 'AM';
                              const _h12 = _h % 12 || 12;
                              _tzDisplay = _h12 + ':' + String(_m).padStart(2, '0') + ' ' + _ap;
                              if (_viewOffset !== null && _viewOffset !== _offOffset) {
                                const _dm = _offOffset - _viewOffset;
                                const _dh = Math.floor(Math.abs(_dm) / 60);
                                const _dmm = Math.abs(_dm) % 60;
                                const _s = _dm > 0 ? '+' : '-';
                                _tzDisplay += ' (' + _s + _dh + (_dmm ? ':' + String(_dmm).padStart(2, '0') : '') + 'h from you)';
                              }
                            }
                          %>
                          <div class="trade-info-row"><span class="trade-info-label">Their Time</span><span class="trade-info-value"><%= _tzDisplay %></span></div>
                        <% } %>
                        <% if (off.additionalInfo) { %>
                          <div class="trade-info-row"><span class="trade-info-label">Info</span><span class="trade-info-value"><%= off.additionalInfo %></span></div>
                        <% } %>
                        <div style="display:flex;gap:0.5rem;margin-top:0.5rem;">
                          <form action="/trade/accept-offer/<%= off.id %>" method="POST" style="display:inline;">
                            <button type="submit" class="btn btn-success btn-sm">Accept</button>
                          </form>
                          <form action="/trade/reject-offer/<%= off.id %>" method="POST" style="display:inline;">
                            <button type="submit" class="btn btn-danger btn-sm">Reject</button>
                          </form>
                        </div>
                      </div>
                    <% }); %>
                  </div>
                <% } %>
              <% } %>

              <% if (trade.status === 'awaiting_confirmation' || trade.status === 'completed') { %>
                <%- renderTradeDetails(trade, 'acceptor', viewerTimezone) %>
                <%- renderTradeDetails(trade, 'creator', viewerTimezone) %>
                <% if (trade.acceptor) { %>
                  <%- renderContactInfo(trade.acceptor, trade.acceptor.username + "'s") %>
                <% } %>
              <% } %>

              <% if (trade.tradeFeedbackAcceptor) { %>
                <div class="trade-feedback-block">
                  <div class="trade-feedback-label">Feedback from <%= trade.acceptor ? trade.acceptor.username : 'acceptor' %></div>
                  <%= trade.tradeFeedbackAcceptor %>
                </div>
              <% } %>
              <% if (trade.tradeFeedbackCreator) { %>
                <div class="trade-feedback-block">
                  <div class="trade-feedback-label">Your feedback</div>
                  <%= trade.tradeFeedbackCreator %>
                </div>
              <% } %>
            </div>

            <div class="trade-actions">
              <% if (trade.status === 'awaiting_confirmation' && !trade.creatorConfirmed) { %>
                <button type="button" class="btn btn-success btn-full" onclick="openConfirmModal('<%= trade.id %>', 'creator')">Confirm Trade</button>
              <% } %>
              <% if (trade.status === 'awaiting_confirmation') { %>
                <button type="button" class="btn btn-danger btn-full" onclick="showStyledConfirm('Decline this trade? This action cannot be undone.', () => { document.getElementById('decline-form-<%= trade.id %>').submit(); })">Decline</button>
                <form id="decline-form-<%= trade.id %>" action="/trade/decline/<%= trade.id %>" method="POST" style="display:none;"></form>
              <% } %>
              <% if (trade.status === 'open') { %>
                <button type="button" class="btn btn-danger btn-full" onclick="showStyledConfirm('Cancel this trade offer?', () => { document.getElementById('cancel-form-<%= trade.id %>').submit(); })">Cancel</button>
                <form id="cancel-form-<%= trade.id %>" action="/trade/cancel/<%= trade.id %>" method="POST" style="display:none;"></form>
              <% } %>
              <% if (trade.status === 'completed' && !trade.creatorRated) { %>
                <form action="/trade/rate/<%= trade.id %>" method="POST" class="rating-form">
                  <div class="rating-row">
                    <select name="rating" required style="flex:1;">
                      <option value="" disabled selected>Rate</option>
                      <% for (let i = 10; i >= 1; i--) { %><option value="<%= i %>"><%= i %>/10</option><% } %>
                    </select>
                    <button type="submit" class="btn btn-primary btn-sm">Submit</button>
                  </div>
                  <textarea name="feedback" placeholder="Trade feedback (optional, visible on their profile)" maxlength="200" oninput="this.nextElementSibling.textContent = this.value.length + '/200'"></textarea>
                  <span style="font-size:0.7rem; color:var(--text-muted);">0/200</span>
                </form>
              <% } %>
              <% if (trade.status === 'completed' && trade.creatorRated) { %>
                <span style="color: var(--text-muted); font-size:0.8rem;">Rated</span>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>

    <!-- ---- Trades I Accepted ---- -->
    <h2 style="margin:2rem 0 1rem;">Trades I Accepted</h2>
    <% if (!acceptedTrades || acceptedTrades.length === 0) { %>
      <div class="no-offers-card">No accepted trades.</div>
    <% } else { %>
      <div class="offers-grid">
        <% acceptedTrades.forEach(trade => {
          const offItems = Array.isArray(trade.offeredItems)    ? trade.offeredItems    : [];
          const reqItems = Array.isArray(trade.requestedItems)  ? trade.requestedItems  : [];
        %>
          <div class="trade-card">
            <% if (trade.game) { %>
              <div class="trade-card-banner" style="<%- getGameBannerStyle(trade.game) %>"><%= trade.gameVariant || trade.game %></div>
            <% } %>
            <div class="trade-card-platform-banner"><%= trade.platform %></div>
            <div class="offer-heading">
              <% if (trade.characterLevel) { %>
                <span class="char-level-badge">LVL <%= trade.characterLevel %></span>
              <% } %>
              <span class="time-ago"><%= getTimeAgo(trade.createdAt) %></span>
              <div style="margin-top:0.5rem;"><%- getStatusBadge(trade) %></div>
            </div>

            <div class="trade-card-inner">
              <div class="offered-col">
                <h2>Offered</h2>
                <% offItems.forEach(item => {
                  const metaParts = [];
                  const _mq = fmtQty(item.qty); if (_mq) metaParts.push('\u00d7' + _mq);
                  if (item.upgrade !== null && item.upgrade !== undefined) metaParts.push('+' + item.upgrade);
                  const meta = metaParts.join(' ');
                %>
                  <div class="trade-item-row">
                    <% if (item.iconPath) { %>
                      <img class="trade-item-icon" src="<%= item.iconPath %>" alt="" onerror="this.style.display='none'">
                    <% } else { %>
                      <div class="trade-item-icon-fallback"><%= item.name.charAt(0) %></div>
                    <% } %>
                    <span class="trade-item-name"><%= item.name %></span>
                    <% if (meta) { %><span class="trade-item-meta"><%= meta %></span><% } %>
                  </div>
                <% }); %>
              </div>
              <div class="requested-col">
                <h2>Requested</h2>
                <% reqItems.forEach(item => {
                  const metaParts = [];
                  const _mq = fmtQty(item.qty); if (_mq) metaParts.push('\u00d7' + _mq);
                  if (item.upgrade !== null && item.upgrade !== undefined) metaParts.push('+' + item.upgrade);
                  const meta = metaParts.join(' ');
                %>
                  <div class="trade-item-row">
                    <% if (item.iconPath) { %>
                      <img class="trade-item-icon" src="<%= item.iconPath %>" alt="" onerror="this.style.display='none'">
                    <% } else { %>
                      <div class="trade-item-icon-fallback"><%= item.name.charAt(0) %></div>
                    <% } %>
                    <span class="trade-item-name"><%= item.name %></span>
                    <% if (meta) { %><span class="trade-item-meta"><%= meta %></span><% } %>
                  </div>
                <% }); %>
              </div>
            </div>

            <!-- Creator info -->
            <div class="trade-details">
              <p style="font-size:0.85rem; margin:0.5rem 0;">
                Created by:
                <span class="user-hover-trigger"
                      data-username="<%= trade.offerCreator.username %>"
                      style="<%= getUsernameStyle(trade.offerCreator.role) %>">
                  <a href="/profile/<%= trade.offerCreator.username %>" style="color:inherit;"><%= trade.offerCreator.username %></a>
                </span>
              </p>

              <% if (trade.status === 'awaiting_confirmation' || trade.status === 'completed') { %>
                <%- renderTradeDetails(trade, 'creator', viewerTimezone) %>
                <%- renderTradeDetails(trade, 'acceptor', viewerTimezone) %>
                <% if (trade.offerCreator) { %>
                  <%- renderContactInfo(trade.offerCreator, trade.offerCreator.username + "'s") %>
                <% } %>
              <% } %>

              <% if (trade.tradeFeedbackCreator) { %>
                <div class="trade-feedback-block">
                  <div class="trade-feedback-label">Feedback from <%= trade.offerCreator ? trade.offerCreator.username : 'creator' %></div>
                  <%= trade.tradeFeedbackCreator %>
                </div>
              <% } %>
              <% if (trade.tradeFeedbackAcceptor) { %>
                <div class="trade-feedback-block">
                  <div class="trade-feedback-label">Your feedback</div>
                  <%= trade.tradeFeedbackAcceptor %>
                </div>
              <% } %>
            </div>

            <div class="trade-actions">
              <% if (trade.status === 'awaiting_confirmation' && !trade.acceptorConfirmed) { %>
                <button type="button" class="btn btn-success btn-full" onclick="openConfirmModal('<%= trade.id %>', 'acceptor')">Confirm Trade</button>
              <% } %>
              <% if (trade.status === 'awaiting_confirmation') { %>
                <button type="button" class="btn btn-danger btn-full" onclick="showStyledConfirm('Decline this trade? This action cannot be undone.', () => { document.getElementById('decline-form-a-<%= trade.id %>').submit(); })">Decline</button>
                <form id="decline-form-a-<%= trade.id %>" action="/trade/decline/<%= trade.id %>" method="POST" style="display:none;"></form>
              <% } %>
              <% if (trade.status === 'completed' && !trade.acceptorRated) { %>
                <form action="/trade/rate/<%= trade.id %>" method="POST" class="rating-form">
                  <div class="rating-row">
                    <select name="rating" required style="flex:1;">
                      <option value="" disabled selected>Rate</option>
                      <% for (let i = 10; i >= 1; i--) { %><option value="<%= i %>"><%= i %>/10</option><% } %>
                    </select>
                    <button type="submit" class="btn btn-primary btn-sm">Submit</button>
                  </div>
                  <textarea name="feedback" placeholder="Trade feedback (optional, visible on their profile)" maxlength="200" oninput="this.nextElementSibling.textContent = this.value.length + '/200'"></textarea>
                  <span style="font-size:0.7rem; color:var(--text-muted);">0/200</span>
                </form>
              <% } %>
              <% if (trade.status === 'completed' && trade.acceptorRated) { %>
                <span style="color: var(--text-muted); font-size:0.8rem;">Rated</span>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>

    <!-- ---- Completed Trades ---- -->
    <h2 style="margin:2rem 0 1rem;">Completed Trades</h2>
    <% if (!completedTrades || completedTrades.length === 0) { %>
      <div class="no-offers-card">No completed trades yet.</div>
    <% } else { %>
      <div class="offers-grid">
        <% completedTrades.forEach(trade => {
          const offItems = Array.isArray(trade.offeredItems) ? trade.offeredItems : [];
          const reqItems = Array.isArray(trade.requestedItems) ? trade.requestedItems : [];
          const isCreator = trade.offerCreatorId === userId;
          const partner = isCreator ? trade.acceptor : trade.offerCreator;
          const partnerName = partner ? partner.username : 'Unknown';
          const partnerRole = partner ? partner.role : 'user';
        %>
          <div class="trade-card">
            <% if (trade.game) { %>
              <div class="trade-card-banner" style="<%- getGameBannerStyle(trade.game) %>"><%= trade.gameVariant || trade.game %></div>
            <% } %>
            <div class="trade-card-platform-banner"><%= trade.platform %></div>
            <div class="offer-heading">
              <% if (trade.characterLevel) { %>
                <span class="char-level-badge">LVL <%= trade.characterLevel %></span>
              <% } %>
              <span class="time-ago"><%= getTimeAgo(trade.updatedAt || trade.createdAt) %></span>
              <div style="margin-top:0.5rem;"><%- getStatusBadge(trade) %></div>
            </div>

            <div class="trade-card-inner">
              <div class="offered-col">
                <h2>Offered</h2>
                <% offItems.forEach(item => {
                  const metaParts = [];
                  const _mq = fmtQty(item.qty); if (_mq) metaParts.push('\u00d7' + _mq);
                  if (item.upgrade !== null && item.upgrade !== undefined) metaParts.push('+' + item.upgrade);
                  const meta = metaParts.join(' ');
                %>
                  <div class="trade-item-row">
                    <% if (item.iconPath) { %>
                      <img class="trade-item-icon" src="<%= item.iconPath %>" alt="" onerror="this.style.display='none'">
                    <% } else { %>
                      <div class="trade-item-icon-fallback"><%= item.name.charAt(0) %></div>
                    <% } %>
                    <span class="trade-item-name"><%= item.name %></span>
                    <% if (meta) { %><span class="trade-item-meta"><%= meta %></span><% } %>
                  </div>
                <% }); %>
              </div>
              <div class="requested-col">
                <h2>Requested</h2>
                <% reqItems.forEach(item => {
                  const metaParts = [];
                  const _mq = fmtQty(item.qty); if (_mq) metaParts.push('\u00d7' + _mq);
                  if (item.upgrade !== null && item.upgrade !== undefined) metaParts.push('+' + item.upgrade);
                  const meta = metaParts.join(' ');
                %>
                  <div class="trade-item-row">
                    <% if (item.iconPath) { %>
                      <img class="trade-item-icon" src="<%= item.iconPath %>" alt="" onerror="this.style.display='none'">
                    <% } else { %>
                      <div class="trade-item-icon-fallback"><%= item.name.charAt(0) %></div>
                    <% } %>
                    <span class="trade-item-name"><%= item.name %></span>
                    <% if (meta) { %><span class="trade-item-meta"><%= meta %></span><% } %>
                  </div>
                <% }); %>
              </div>
            </div>

            <div class="trade-details">
              <p style="font-size:0.85rem; margin:0.5rem 0;">
                Trade with:
                <span class="user-hover-trigger"
                      data-username="<%= partnerName %>"
                      style="<%= getUsernameStyle(partnerRole) %>">
                  <a href="/profile/<%= partnerName %>" style="color:inherit;"><%= partnerName %></a>
                </span>
              </p>

              <%- renderTradeDetails(trade, 'creator', viewerTimezone) %>
              <%- renderTradeDetails(trade, 'acceptor', viewerTimezone) %>

              <% if (isCreator && trade.tradeFeedbackAcceptor) { %>
                <div class="trade-feedback-block">
                  <div class="trade-feedback-label">Feedback from <%= partnerName %></div>
                  <%= trade.tradeFeedbackAcceptor %>
                </div>
              <% } %>
              <% if (isCreator && trade.tradeFeedbackCreator) { %>
                <div class="trade-feedback-block">
                  <div class="trade-feedback-label">Your feedback</div>
                  <%= trade.tradeFeedbackCreator %>
                </div>
              <% } %>
              <% if (!isCreator && trade.tradeFeedbackCreator) { %>
                <div class="trade-feedback-block">
                  <div class="trade-feedback-label">Feedback from <%= partnerName %></div>
                  <%= trade.tradeFeedbackCreator %>
                </div>
              <% } %>
              <% if (!isCreator && trade.tradeFeedbackAcceptor) { %>
                <div class="trade-feedback-block">
                  <div class="trade-feedback-label">Your feedback</div>
                  <%= trade.tradeFeedbackAcceptor %>
                </div>
              <% } %>
            </div>

            <div class="trade-actions">
              <% if (isCreator && !trade.creatorRated) { %>
                <form action="/trade/rate/<%= trade.id %>" method="POST" class="rating-form">
                  <div class="rating-row">
                    <select name="rating" required style="flex:1;">
                      <option value="" disabled selected>Rate</option>
                      <% for (let i = 10; i >= 1; i--) { %><option value="<%= i %>"><%= i %>/10</option><% } %>
                    </select>
                    <button type="submit" class="btn btn-primary btn-sm">Submit</button>
                  </div>
                  <textarea name="feedback" placeholder="Trade feedback (optional, visible on their profile)" maxlength="200" oninput="this.nextElementSibling.textContent = this.value.length + '/200'"></textarea>
                  <span style="font-size:0.7rem; color:var(--text-muted);">0/200</span>
                </form>
              <% } else if (isCreator && trade.creatorRated) { %>
                <span style="color: var(--text-muted); font-size:0.8rem;">Rated</span>
              <% } %>
              <% if (!isCreator && !trade.acceptorRated) { %>
                <form action="/trade/rate/<%= trade.id %>" method="POST" class="rating-form">
                  <div class="rating-row">
                    <select name="rating" required style="flex:1;">
                      <option value="" disabled selected>Rate</option>
                      <% for (let i = 10; i >= 1; i--) { %><option value="<%= i %>"><%= i %>/10</option><% } %>
                    </select>
                    <button type="submit" class="btn btn-primary btn-sm">Submit</button>
                  </div>
                  <textarea name="feedback" placeholder="Trade feedback (optional, visible on their profile)" maxlength="200" oninput="this.nextElementSibling.textContent = this.value.length + '/200'"></textarea>
                  <span style="font-size:0.7rem; color:var(--text-muted);">0/200</span>
                </form>
              <% } else if (!isCreator && trade.acceptorRated) { %>
                <span style="color: var(--text-muted); font-size:0.8rem;">Rated</span>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>

    <!-- ---- My Pending Offers (trades I've offered on but haven't been accepted yet) ---- -->
    <% if (typeof pendingOffers !== 'undefined' && pendingOffers.length > 0) { %>
      <h2 style="margin:2rem 0 1rem;">My Pending Offers</h2>
      <div class="offers-grid">
        <% pendingOffers.forEach(po => {
          const trade = po.trade;
          if (!trade) return;
          const offItems = Array.isArray(trade.offeredItems) ? trade.offeredItems : [];
          const reqItems = Array.isArray(trade.requestedItems) ? trade.requestedItems : [];
        %>
          <div class="trade-card">
            <% if (trade.game) { %>
              <div class="trade-card-banner" style="<%- getGameBannerStyle(trade.game) %>"><%= trade.gameVariant || trade.game %></div>
            <% } %>
            <div class="trade-card-platform-banner"><%= trade.platform %></div>
            <div class="offer-heading">
              <span class="time-ago">Offered <%= getTimeAgo(po.createdAt) %></span>
              <div style="margin-top:0.5rem;"><span class="status-badge status-awaiting">Offer Pending</span></div>
            </div>
            <div class="trade-card-inner">
              <div class="offered-col">
                <h2>They Offer</h2>
                <% offItems.forEach(item => {
                  const metaParts = [];
                  const _mq = fmtQty(item.qty); if (_mq) metaParts.push('\u00d7' + _mq);
                  if (item.upgrade !== null && item.upgrade !== undefined) metaParts.push('+' + item.upgrade);
                  const meta = metaParts.join(' ');
                %>
                  <div class="trade-item-row">
                    <% if (item.iconPath) { %>
                      <img class="trade-item-icon" src="<%= item.iconPath %>" alt="" onerror="this.style.display='none'">
                    <% } else { %>
                      <div class="trade-item-icon-fallback"><%= item.name.charAt(0) %></div>
                    <% } %>
                    <span class="trade-item-name"><%= item.name %></span>
                    <% if (meta) { %><span class="trade-item-meta"><%= meta %></span><% } %>
                  </div>
                <% }); %>
              </div>
              <div class="requested-col">
                <h2>They Want</h2>
                <% reqItems.forEach(item => {
                  const metaParts = [];
                  const _mq = fmtQty(item.qty); if (_mq) metaParts.push('\u00d7' + _mq);
                  if (item.upgrade !== null && item.upgrade !== undefined) metaParts.push('+' + item.upgrade);
                  const meta = metaParts.join(' ');
                %>
                  <div class="trade-item-row">
                    <% if (item.iconPath) { %>
                      <img class="trade-item-icon" src="<%= item.iconPath %>" alt="" onerror="this.style.display='none'">
                    <% } else { %>
                      <div class="trade-item-icon-fallback"><%= item.name.charAt(0) %></div>
                    <% } %>
                    <span class="trade-item-name"><%= item.name %></span>
                    <% if (meta) { %><span class="trade-item-meta"><%= meta %></span><% } %>
                  </div>
                <% }); %>
              </div>
            </div>
            <div class="trade-details">
              <p style="font-size:0.85rem; margin:0.5rem 0;">
                Created by:
                <span class="user-hover-trigger" data-username="<%= trade.offerCreator ? trade.offerCreator.username : 'Unknown' %>"
                      style="<%= trade.offerCreator ? getUsernameStyle(trade.offerCreator.role) : '' %>">
                  <a href="/profile/<%= trade.offerCreator ? trade.offerCreator.username : '' %>" style="color:inherit;"><%= trade.offerCreator ? trade.offerCreator.username : 'Unknown' %></a>
                </span>
              </p>
              <% if (po.inGameName || po.meetingPoint) { %>
                <div class="trade-info-section">
                  <h3>Your Offer Details</h3>
                  <% if (po.inGameName) { %>
                    <div class="trade-info-row"><span class="trade-info-label">Character</span><span class="trade-info-value"><%= po.inGameName %></span></div>
                  <% } %>
                  <% if (po.meetingPoint) { %>
                    <div class="trade-info-row"><span class="trade-info-label">Meeting Point</span><span class="trade-info-value"><%= po.meetingPoint %></span></div>
                  <% } %>
                </div>
              <% } %>
            </div>
            <div class="trade-actions">
              <form action="/trade/rescind-offer/<%= po.id %>" method="POST" style="flex:1;">
                <button type="submit" class="btn btn-danger btn-full" onclick="return confirm('Rescind your offer on this trade?')">Rescind Offer</button>
              </form>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>

    <!-- ---- Expired Trades ---- -->
    <% if (typeof expiredTrades !== 'undefined' && expiredTrades.length > 0) { %>
      <h2 style="margin:2rem 0 1rem;">Expired Trades</h2>
      <div class="offers-grid">
        <% expiredTrades.forEach(trade => {
          const offItems = Array.isArray(trade.offeredItems) ? trade.offeredItems : [];
          const reqItems = Array.isArray(trade.requestedItems) ? trade.requestedItems : [];
          const isCreator = trade.offerCreatorId === userId;
          const partner = isCreator ? trade.acceptor : trade.offerCreator;
          const partnerName = partner ? partner.username : 'Unknown';
          const partnerRole = partner ? partner.role : 'user';
        %>
          <div class="trade-card" style="opacity:0.7;">
            <% if (trade.game) { %>
              <div class="trade-card-banner" style="<%- getGameBannerStyle(trade.game) %>"><%= trade.gameVariant || trade.game %></div>
            <% } %>
            <div class="trade-card-platform-banner"><%= trade.platform %></div>
            <div class="offer-heading">
              <% if (trade.characterLevel) { %>
                <span class="char-level-badge">LVL <%= trade.characterLevel %></span>
              <% } %>
              <span class="time-ago"><%= getTimeAgo(trade.createdAt) %></span>
              <div style="margin-top:0.5rem;"><span class="status-badge status-declined">Expired</span></div>
            </div>
            <div class="trade-card-inner">
              <div class="offered-col">
                <h2>Offered</h2>
                <% offItems.forEach(item => {
                  const metaParts = [];
                  const _mq = fmtQty(item.qty); if (_mq) metaParts.push('\u00d7' + _mq);
                  if (item.upgrade !== null && item.upgrade !== undefined) metaParts.push('+' + item.upgrade);
                  const meta = metaParts.join(' ');
                %>
                  <div class="trade-item-row">
                    <% if (item.iconPath) { %>
                      <img class="trade-item-icon" src="<%= item.iconPath %>" alt="" onerror="this.style.display='none'">
                    <% } else { %>
                      <div class="trade-item-icon-fallback"><%= item.name.charAt(0) %></div>
                    <% } %>
                    <span class="trade-item-name"><%= item.name %></span>
                    <% if (meta) { %><span class="trade-item-meta"><%= meta %></span><% } %>
                  </div>
                <% }); %>
              </div>
              <div class="requested-col">
                <h2>Requested</h2>
                <% reqItems.forEach(item => {
                  const metaParts = [];
                  const _mq = fmtQty(item.qty); if (_mq) metaParts.push('\u00d7' + _mq);
                  if (item.upgrade !== null && item.upgrade !== undefined) metaParts.push('+' + item.upgrade);
                  const meta = metaParts.join(' ');
                %>
                  <div class="trade-item-row">
                    <% if (item.iconPath) { %>
                      <img class="trade-item-icon" src="<%= item.iconPath %>" alt="" onerror="this.style.display='none'">
                    <% } else { %>
                      <div class="trade-item-icon-fallback"><%= item.name.charAt(0) %></div>
                    <% } %>
                    <span class="trade-item-name"><%= item.name %></span>
                    <% if (meta) { %><span class="trade-item-meta"><%= meta %></span><% } %>
                  </div>
                <% }); %>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>

  <!-- ═══ Confirm Trade Modal ═══ -->
  <div class="confirm-modal-overlay" id="confirmTradeModal">
    <div class="confirm-modal-box">
      <h3>Confirm Trade</h3>
      <form id="confirmTradeForm" method="POST">
        <div class="confirm-warning">
          <strong>This action is final.</strong> Once both parties confirm, the trade is marked as completed and cannot be undone. Please ensure you have completed the in-game trade before confirming.
        </div>

        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;font-size:0.9rem;margin:1rem 0;">
          <input type="checkbox" id="confirmCheckbox" />
          <span>I confirm I have completed this trade in-game.</span>
        </label>

        <div class="confirm-modal-actions">
          <button type="button" class="btn btn-secondary" onclick="closeConfirmModal()">Cancel</button>
          <button type="submit" class="btn btn-success" id="confirmSubmitBtn" disabled>Confirm Trade</button>
        </div>
      </form>
    </div>
  </div>

  <!-- ═══ Styled Confirm Modal (replaces browser confirm()) ═══ -->
  <div class="confirm-modal-overlay" id="styledConfirmModal">
    <div class="confirm-modal-box">
      <h3 id="styledConfirmTitle">Confirm</h3>
      <p id="styledConfirmMessage" style="color:var(--text-secondary);margin-bottom:1rem;font-size:0.9rem;"></p>
      <div class="confirm-modal-actions">
        <button type="button" class="btn btn-secondary" onclick="closeStyledConfirm()">Cancel</button>
        <button type="button" class="btn btn-danger" id="styledConfirmYes">Confirm</button>
      </div>
    </div>
  </div>

  <!-- ═══ Post-Trade Feedback Prompt Modal ═══ -->
  <div class="feedback-prompt-overlay" id="feedbackPromptModal">
    <div class="feedback-prompt-box">
      <h3>Thanks for trading on SoulTrader!</h3>
      <p class="feedback-prompt-sub">How was your experience? Leave feedback for your trade partner.</p>
      <form id="feedbackPromptForm" method="POST" class="rating-form">
        <div class="rating-row">
          <select name="rating" required style="flex:1;">
            <option value="" disabled selected>Rate 1–10</option>
            <% for (let i = 10; i >= 1; i--) { %><option value="<%= i %>"><%= i %>/10</option><% } %>
          </select>
          <button type="submit" class="btn btn-primary btn-sm">Submit</button>
        </div>
        <textarea name="feedback" placeholder="Trade feedback (optional, visible on their profile)" maxlength="200" oninput="this.nextElementSibling.textContent = this.value.length + '/200'"></textarea>
        <span style="font-size:0.7rem; color:var(--text-muted);">0/200</span>
      </form>
      <button type="button" class="feedback-prompt-skip" onclick="closeFeedbackPrompt()">Skip for now</button>
    </div>
  </div>

  <%- include('partials/preloader') %>
  <%- include('partials/auth-modals') %>
  <%- include('partials/footer') %>
  <script src="/js/auth.js"></script>
  <script src="/js/user-hover.js"></script>
  <script>
    // ── Confirm Trade Modal ──
    function openConfirmModal(tradeId, role) {
      const modal = document.getElementById('confirmTradeModal');
      const form = document.getElementById('confirmTradeForm');
      const checkbox = document.getElementById('confirmCheckbox');
      const submitBtn = document.getElementById('confirmSubmitBtn');
      form.action = '/trade/confirm/' + tradeId;
      checkbox.checked = false;
      submitBtn.disabled = true;
      modal.classList.add('active');
    }
    function closeConfirmModal() {
      document.getElementById('confirmTradeModal').classList.remove('active');
    }
    document.getElementById('confirmCheckbox').addEventListener('change', function() {
      document.getElementById('confirmSubmitBtn').disabled = !this.checked;
    });
    document.getElementById('confirmTradeModal').addEventListener('click', function(e) {
      if (e.target === this) closeConfirmModal();
    });

    // ── Styled Confirm Modal (replaces browser confirm()) ──
    let _styledConfirmCb = null;
    function showStyledConfirm(message, onConfirm) {
      const modal = document.getElementById('styledConfirmModal');
      document.getElementById('styledConfirmMessage').textContent = message;
      _styledConfirmCb = onConfirm;
      modal.classList.add('active');
    }
    function closeStyledConfirm() {
      document.getElementById('styledConfirmModal').classList.remove('active');
      _styledConfirmCb = null;
    }
    document.getElementById('styledConfirmYes').addEventListener('click', () => {
      if (_styledConfirmCb) _styledConfirmCb();
      closeStyledConfirm();
    });
    document.getElementById('styledConfirmModal').addEventListener('click', function(e) {
      if (e.target === this) closeStyledConfirm();
    });

    // ── Post-Trade Feedback Prompt ──
    function closeFeedbackPrompt() {
      document.getElementById('feedbackPromptModal').classList.remove('active');
    }
    document.getElementById('feedbackPromptModal').addEventListener('click', function(e) {
      if (e.target === this) closeFeedbackPrompt();
    });

    // Check if we should show the feedback prompt (query param: feedbackFor=<tradeId>)
    (function() {
      const params = new URLSearchParams(window.location.search);
      const feedbackTradeId = params.get('feedbackFor');
      if (feedbackTradeId) {
        const form = document.getElementById('feedbackPromptForm');
        if (form) {
          form.action = '/trade/rate/' + feedbackTradeId;
          document.getElementById('feedbackPromptModal').classList.add('active');
        }
        // Clean URL
        const url = new URL(window.location);
        url.searchParams.delete('feedbackFor');
        window.history.replaceState({}, '', url);
      }
    })();

    // Close any modal on Escape
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        closeConfirmModal();
        closeStyledConfirm();
        closeFeedbackPrompt();
      }
    });
  </script>
</body>
</html>
