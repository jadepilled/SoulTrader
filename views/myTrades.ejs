<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Trades | SoulTrader</title>
  <link rel="icon" type="image/x-icon" href="/icons/favicon.ico">
  <link href="https://fonts.googleapis.com/css2?family=Spectral:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/responsive.css">
  <style>
    .trade-info-section {
      margin-top: 0.75rem;
      padding: 0.75rem;
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: var(--radius);
    }
    .trade-info-section h3 {
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--text-muted);
      margin-bottom: 0.5rem;
    }
    .trade-info-row {
      display: flex;
      gap: 0.5rem;
      font-size: 0.82rem;
      padding: 0.2rem 0;
    }
    .trade-info-label {
      color: var(--text-muted);
      min-width: 100px;
      flex-shrink: 0;
    }
    .trade-info-value {
      color: var(--text-primary);
      word-break: break-word;
    }
    .trade-contact-section {
      margin-top: 0.5rem;
      padding: 0.5rem 0.75rem;
      background: rgba(var(--accent-rgb, 138,138,138), 0.06);
      border: 1px solid rgba(var(--accent-rgb, 138,138,138), 0.12);
      border-radius: var(--radius);
    }
    .trade-contact-section h4 {
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--text-muted);
      margin-bottom: 0.35rem;
    }
    /* Confirm modal */
    .confirm-modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.7);
      z-index: 5000;
      align-items: center;
      justify-content: center;
    }
    .confirm-modal-overlay.active {
      display: flex;
    }
    .confirm-modal-box {
      background: var(--bg-secondary);
      border: 1px solid var(--border-color);
      border-radius: var(--radius-lg);
      padding: 1.5rem;
      max-width: 480px;
      width: 90%;
      max-height: 90vh;
      overflow-y: auto;
    }
    .confirm-modal-box h3 {
      margin-bottom: 0.75rem;
      font-size: 1.1rem;
    }
    .confirm-modal-box label {
      display: block;
      font-size: 0.85rem;
      margin-top: 0.6rem;
      margin-bottom: 0.25rem;
      color: var(--text-secondary);
    }
    .confirm-modal-box input,
    .confirm-modal-box textarea {
      width: 100%;
      padding: 0.45rem 0.6rem;
      background: var(--bg-input);
      border: 1px solid var(--border-color);
      border-radius: var(--radius);
      color: var(--text-primary);
      font-family: var(--font);
      font-size: 0.85rem;
    }
    .confirm-modal-box textarea {
      resize: vertical;
      min-height: 60px;
    }
    .confirm-warning {
      margin-top: 1rem;
      padding: 0.6rem;
      background: rgba(234, 179, 8, 0.08);
      border: 1px solid rgba(234, 179, 8, 0.2);
      border-radius: var(--radius);
      font-size: 0.82rem;
      color: var(--warning);
      line-height: 1.5;
    }
    .confirm-modal-actions {
      display: flex;
      gap: 0.5rem;
      margin-top: 1rem;
    }
    .confirm-modal-actions .btn { flex: 1; }
    /* Rating form */
    .rating-form {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .rating-form .rating-row {
      display: flex;
      gap: 0.5rem;
      align-items: center;
    }
    .rating-form textarea {
      width: 100%;
      padding: 0.4rem 0.6rem;
      background: var(--bg-input);
      border: 1px solid var(--border-color);
      border-radius: var(--radius);
      color: var(--text-primary);
      font-family: var(--font);
      font-size: 0.82rem;
      resize: vertical;
      min-height: 50px;
    }
    /* Feedback display */
    .trade-feedback-block {
      margin-top: 0.5rem;
      padding: 0.5rem 0.75rem;
      background: rgba(34, 197, 94, 0.05);
      border-left: 3px solid var(--success);
      border-radius: 0 var(--radius) var(--radius) 0;
      font-size: 0.82rem;
    }
    .trade-feedback-block.negative {
      background: rgba(239, 68, 68, 0.05);
      border-left-color: var(--danger);
    }
    .trade-feedback-label {
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--text-muted);
      margin-bottom: 0.2rem;
    }
  </style>
</head>
<body>
  <%- include('partials/navbar', { title: 'My Trades', gameKey: '', pendingTradeCount: typeof pendingTradeCount !== 'undefined' ? pendingTradeCount : 0 }) %>
  <%- include('partials/flash-messages') %>

  <div class="main-content">
    <h1 class="section-title" style="margin-top:0.5rem;">My Trades</h1>

    <%
      const gameColorMap = {
        'Dark Souls':    { color: '#7b86a2', rgb: '123, 134, 162' },
        'Dark Souls 2':  { color: '#8b7eaa', rgb: '139, 126, 170' },
        'Dark Souls 3':  { color: '#6e7fa0', rgb: '110, 127, 160' },
        'Bloodborne':    { color: '#8b3a3a', rgb: '139, 58, 58' },
        'Elden Ring':    { color: '#c8a84e', rgb: '200, 168, 78' },
        "Demon's Souls": { color: '#8a8a8a', rgb: '138, 138, 138' },
      };

      function getGameBannerStyle(gameName) {
        const gc = gameColorMap[gameName] || { color: '#8a8a8a', rgb: '138, 138, 138' };
        return `background: rgba(${gc.rgb}, 0.2); color: ${gc.color}; border-bottom: 1px solid rgba(${gc.rgb}, 0.3);`;
      }

      function getStatusBadge(trade) {
        const s = trade.status;
        if (s === 'open') return '<span class="status-badge status-open">Open</span>';
        if (s === 'awaiting_confirmation') {
          let detail = '';
          if (trade.creatorConfirmed && !trade.acceptorConfirmed) detail = ' (Creator confirmed)';
          else if (!trade.creatorConfirmed && trade.acceptorConfirmed) detail = ' (Acceptor confirmed)';
          else detail = ' (Awaiting both)';
          return '<span class="status-badge status-awaiting">Awaiting Confirmation' + detail + '</span>';
        }
        if (s === 'completed') return '<span class="status-badge status-completed">Completed</span>';
        if (s === 'declined') return '<span class="status-badge status-declined">Declined</span>';
        if (s === 'cancelled') return '<span class="status-badge status-cancelled">Cancelled</span>';
        return '<span class="status-badge">' + s + '</span>';
      }

      function getTimeAgo(createdAt) {
        const now  = new Date();
        const diff = now - createdAt;
        const mins = Math.floor(diff / 60000);
        if (mins < 1)    return 'just now';
        if (mins < 60)   return mins + 'm ago';
        if (mins < 1440) return Math.floor(mins / 60) + 'h ago';
        return Math.floor(mins / 1440) + 'd ago';
      }

      // Helper to render trade party details
      function renderTradeDetails(trade, partyType) {
        // partyType: 'creator' or 'acceptor'
        const prefix = partyType;
        const ign = trade[prefix + 'InGameName'];
        const meeting = trade[prefix + 'MeetingPoint'];
        const info = trade[prefix + 'AdditionalInfo'];
        if (!ign && !meeting && !info) return '';

        let html = '<div class="trade-info-section"><h3>' + (partyType === 'creator' ? "Creator's" : "Acceptor's") + ' Details</h3>';
        if (ign)     html += '<div class="trade-info-row"><span class="trade-info-label">In-Game Name</span><span class="trade-info-value">' + ign + '</span></div>';
        if (meeting) html += '<div class="trade-info-row"><span class="trade-info-label">Meeting Point</span><span class="trade-info-value">' + meeting + '</span></div>';
        if (info)    html += '<div class="trade-info-row"><span class="trade-info-label">Additional Info</span><span class="trade-info-value">' + info + '</span></div>';
        html += '</div>';
        return html;
      }

      // Helper to render connected contact info for a user
      function renderContactInfo(user, label) {
        if (!user) return '';
        const c = [];
        if (user.contactDiscord) c.push('<div class="trade-info-row"><span class="trade-info-label">Discord</span><span class="trade-info-value">' + user.contactDiscord + '</span></div>');
        if (user.contactSteam)   c.push('<div class="trade-info-row"><span class="trade-info-label">Steam</span><span class="trade-info-value">' + user.contactSteam + '</span></div>');
        if (user.contactPSN)     c.push('<div class="trade-info-row"><span class="trade-info-label">PSN</span><span class="trade-info-value">' + user.contactPSN + '</span></div>');
        if (user.contactXbox)    c.push('<div class="trade-info-row"><span class="trade-info-label">Xbox</span><span class="trade-info-value">' + user.contactXbox + '</span></div>');
        if (c.length === 0) return '';
        return '<div class="trade-contact-section"><h4>' + label + ' Contact Info</h4>' + c.join('') + '</div>';
      }
    %>

    <!-- ---- Trades I Created ---- -->
    <h2 style="margin:2rem 0 1rem;">Trades I Created</h2>
    <% if (!createdTrades || createdTrades.length === 0) { %>
      <div class="no-offers-card">No trades created yet.</div>
    <% } else { %>
      <div class="offers-grid">
        <% createdTrades.forEach(trade => {
          const offItems = Array.isArray(trade.offeredItems)    ? trade.offeredItems    : [];
          const reqItems = Array.isArray(trade.requestedItems)  ? trade.requestedItems  : [];
        %>
          <div class="trade-card">
            <% if (trade.game) { %>
              <div class="trade-card-banner" style="<%- getGameBannerStyle(trade.game) %>"><%= trade.game %></div>
            <% } %>
            <div class="offer-heading">
              <% if (trade.characterLevel) { %>
                <span class="char-level-badge">LVL <%= trade.characterLevel %></span>
              <% } %>
              <span class="platform"><%= trade.platform %></span>
              <span class="time-ago"><%= getTimeAgo(trade.createdAt) %></span>
              <div style="margin-top:0.5rem;"><%- getStatusBadge(trade) %></div>
            </div>

            <div class="trade-card-inner">
              <div class="offered-col">
                <h2>Offered</h2>
                <% offItems.forEach(item => {
                  const metaParts = [];
                  const _mq = fmtQty(item.qty); if (_mq) metaParts.push('\u00d7' + _mq);
                  if (item.upgrade !== null && item.upgrade !== undefined) metaParts.push('+' + item.upgrade);
                  const meta = metaParts.join(' ');
                %>
                  <div class="trade-item-row">
                    <% if (item.iconPath) { %>
                      <img class="trade-item-icon" src="<%= item.iconPath %>" alt="" onerror="this.style.display='none'">
                    <% } else { %>
                      <div class="trade-item-icon-fallback"><%= item.name.charAt(0) %></div>
                    <% } %>
                    <span class="trade-item-name"><%= item.name %></span>
                    <% if (meta) { %><span class="trade-item-meta"><%= meta %></span><% } %>
                  </div>
                <% }); %>
              </div>
              <div class="requested-col">
                <h2>Requested</h2>
                <% reqItems.forEach(item => {
                  const metaParts = [];
                  const _mq = fmtQty(item.qty); if (_mq) metaParts.push('\u00d7' + _mq);
                  if (item.upgrade !== null && item.upgrade !== undefined) metaParts.push('+' + item.upgrade);
                  const meta = metaParts.join(' ');
                %>
                  <div class="trade-item-row">
                    <% if (item.iconPath) { %>
                      <img class="trade-item-icon" src="<%= item.iconPath %>" alt="" onerror="this.style.display='none'">
                    <% } else { %>
                      <div class="trade-item-icon-fallback"><%= item.name.charAt(0) %></div>
                    <% } %>
                    <span class="trade-item-name"><%= item.name %></span>
                    <% if (meta) { %><span class="trade-item-meta"><%= meta %></span><% } %>
                  </div>
                <% }); %>
              </div>
            </div>

            <!-- Acceptor info -->
            <div class="trade-details">
              <% if (trade.acceptor) { %>
                <p style="font-size:0.85rem; margin:0.5rem 0;">
                  Accepted by:
                  <span class="user-hover-trigger"
                        data-username="<%= trade.acceptor.username %>"
                        style="<%= getUsernameStyle(trade.acceptor.role) %>">
                    <a href="/profile/<%= trade.acceptor.username %>" style="color:inherit;"><%= trade.acceptor.username %></a>
                  </span>
                </p>
              <% } %>

              <% if (trade.status === 'awaiting_confirmation' || trade.status === 'completed') { %>
                <%- renderTradeDetails(trade, 'acceptor') %>
                <%- renderTradeDetails(trade, 'creator') %>
                <% if (trade.acceptor) { %>
                  <%- renderContactInfo(trade.acceptor, trade.acceptor.username + "'s") %>
                <% } %>
              <% } %>

              <% if (trade.tradeFeedbackAcceptor) { %>
                <div class="trade-feedback-block">
                  <div class="trade-feedback-label">Feedback from <%= trade.acceptor ? trade.acceptor.username : 'acceptor' %></div>
                  <%= trade.tradeFeedbackAcceptor %>
                </div>
              <% } %>
              <% if (trade.tradeFeedbackCreator) { %>
                <div class="trade-feedback-block">
                  <div class="trade-feedback-label">Your feedback</div>
                  <%= trade.tradeFeedbackCreator %>
                </div>
              <% } %>
            </div>

            <div class="trade-actions">
              <% if (trade.status === 'awaiting_confirmation' && !trade.creatorConfirmed) { %>
                <button type="button" class="btn btn-success btn-full" onclick="openConfirmModal('<%= trade.id %>', 'creator')">Confirm Trade</button>
              <% } %>
              <% if (trade.status === 'awaiting_confirmation') { %>
                <form action="/trade/decline/<%= trade.id %>" method="POST" style="flex:1;" onsubmit="return confirm('Decline this trade?');">
                  <button type="submit" class="btn btn-danger btn-full">Decline</button>
                </form>
              <% } %>
              <% if (trade.status === 'open') { %>
                <form action="/trade/cancel/<%= trade.id %>" method="POST" style="flex:1;" onsubmit="return confirm('Cancel this trade?');">
                  <button type="submit" class="btn btn-danger btn-full">Cancel</button>
                </form>
              <% } %>
              <% if (trade.status === 'completed' && !trade.creatorRated) { %>
                <form action="/trade/rate/<%= trade.id %>" method="POST" class="rating-form">
                  <div class="rating-row">
                    <select name="rating" required style="flex:1;">
                      <option value="" disabled selected>Rate</option>
                      <% for (let i = 10; i >= 1; i--) { %><option value="<%= i %>"><%= i %>/10</option><% } %>
                    </select>
                    <button type="submit" class="btn btn-primary btn-sm">Submit</button>
                  </div>
                  <textarea name="feedback" placeholder="Trade feedback (optional, visible on their profile)" maxlength="500"></textarea>
                </form>
              <% } %>
              <% if (trade.status === 'completed' && trade.creatorRated) { %>
                <span style="color: var(--text-muted); font-size:0.8rem;">Rated</span>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>

    <!-- ---- Trades I Accepted ---- -->
    <h2 style="margin:2rem 0 1rem;">Trades I Accepted</h2>
    <% if (!acceptedTrades || acceptedTrades.length === 0) { %>
      <div class="no-offers-card">No accepted trades.</div>
    <% } else { %>
      <div class="offers-grid">
        <% acceptedTrades.forEach(trade => {
          const offItems = Array.isArray(trade.offeredItems)    ? trade.offeredItems    : [];
          const reqItems = Array.isArray(trade.requestedItems)  ? trade.requestedItems  : [];
        %>
          <div class="trade-card">
            <% if (trade.game) { %>
              <div class="trade-card-banner" style="<%- getGameBannerStyle(trade.game) %>"><%= trade.game %></div>
            <% } %>
            <div class="offer-heading">
              <% if (trade.characterLevel) { %>
                <span class="char-level-badge">LVL <%= trade.characterLevel %></span>
              <% } %>
              <span class="platform"><%= trade.platform %></span>
              <span class="time-ago"><%= getTimeAgo(trade.createdAt) %></span>
              <div style="margin-top:0.5rem;"><%- getStatusBadge(trade) %></div>
            </div>

            <div class="trade-card-inner">
              <div class="offered-col">
                <h2>Offered</h2>
                <% offItems.forEach(item => {
                  const metaParts = [];
                  const _mq = fmtQty(item.qty); if (_mq) metaParts.push('\u00d7' + _mq);
                  if (item.upgrade !== null && item.upgrade !== undefined) metaParts.push('+' + item.upgrade);
                  const meta = metaParts.join(' ');
                %>
                  <div class="trade-item-row">
                    <% if (item.iconPath) { %>
                      <img class="trade-item-icon" src="<%= item.iconPath %>" alt="" onerror="this.style.display='none'">
                    <% } else { %>
                      <div class="trade-item-icon-fallback"><%= item.name.charAt(0) %></div>
                    <% } %>
                    <span class="trade-item-name"><%= item.name %></span>
                    <% if (meta) { %><span class="trade-item-meta"><%= meta %></span><% } %>
                  </div>
                <% }); %>
              </div>
              <div class="requested-col">
                <h2>Requested</h2>
                <% reqItems.forEach(item => {
                  const metaParts = [];
                  const _mq = fmtQty(item.qty); if (_mq) metaParts.push('\u00d7' + _mq);
                  if (item.upgrade !== null && item.upgrade !== undefined) metaParts.push('+' + item.upgrade);
                  const meta = metaParts.join(' ');
                %>
                  <div class="trade-item-row">
                    <% if (item.iconPath) { %>
                      <img class="trade-item-icon" src="<%= item.iconPath %>" alt="" onerror="this.style.display='none'">
                    <% } else { %>
                      <div class="trade-item-icon-fallback"><%= item.name.charAt(0) %></div>
                    <% } %>
                    <span class="trade-item-name"><%= item.name %></span>
                    <% if (meta) { %><span class="trade-item-meta"><%= meta %></span><% } %>
                  </div>
                <% }); %>
              </div>
            </div>

            <!-- Creator info -->
            <div class="trade-details">
              <p style="font-size:0.85rem; margin:0.5rem 0;">
                Created by:
                <span class="user-hover-trigger"
                      data-username="<%= trade.offerCreator.username %>"
                      style="<%= getUsernameStyle(trade.offerCreator.role) %>">
                  <a href="/profile/<%= trade.offerCreator.username %>" style="color:inherit;"><%= trade.offerCreator.username %></a>
                </span>
              </p>

              <% if (trade.status === 'awaiting_confirmation' || trade.status === 'completed') { %>
                <%- renderTradeDetails(trade, 'creator') %>
                <%- renderTradeDetails(trade, 'acceptor') %>
                <% if (trade.offerCreator) { %>
                  <%- renderContactInfo(trade.offerCreator, trade.offerCreator.username + "'s") %>
                <% } %>
              <% } %>

              <% if (trade.tradeFeedbackCreator) { %>
                <div class="trade-feedback-block">
                  <div class="trade-feedback-label">Feedback from <%= trade.offerCreator ? trade.offerCreator.username : 'creator' %></div>
                  <%= trade.tradeFeedbackCreator %>
                </div>
              <% } %>
              <% if (trade.tradeFeedbackAcceptor) { %>
                <div class="trade-feedback-block">
                  <div class="trade-feedback-label">Your feedback</div>
                  <%= trade.tradeFeedbackAcceptor %>
                </div>
              <% } %>
            </div>

            <div class="trade-actions">
              <% if (trade.status === 'awaiting_confirmation' && !trade.acceptorConfirmed) { %>
                <button type="button" class="btn btn-success btn-full" onclick="openConfirmModal('<%= trade.id %>', 'acceptor')">Confirm Trade</button>
              <% } %>
              <% if (trade.status === 'awaiting_confirmation') { %>
                <form action="/trade/decline/<%= trade.id %>" method="POST" style="flex:1;" onsubmit="return confirm('Decline this trade?');">
                  <button type="submit" class="btn btn-danger btn-full">Decline</button>
                </form>
              <% } %>
              <% if (trade.status === 'completed' && !trade.acceptorRated) { %>
                <form action="/trade/rate/<%= trade.id %>" method="POST" class="rating-form">
                  <div class="rating-row">
                    <select name="rating" required style="flex:1;">
                      <option value="" disabled selected>Rate</option>
                      <% for (let i = 10; i >= 1; i--) { %><option value="<%= i %>"><%= i %>/10</option><% } %>
                    </select>
                    <button type="submit" class="btn btn-primary btn-sm">Submit</button>
                  </div>
                  <textarea name="feedback" placeholder="Trade feedback (optional, visible on their profile)" maxlength="500"></textarea>
                </form>
              <% } %>
              <% if (trade.status === 'completed' && trade.acceptorRated) { %>
                <span style="color: var(--text-muted); font-size:0.8rem;">Rated</span>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>

  <!-- ═══ Confirm Trade Modal ═══ -->
  <div class="confirm-modal-overlay" id="confirmTradeModal">
    <div class="confirm-modal-box">
      <h3>Confirm Trade</h3>
      <form id="confirmTradeForm" method="POST">
        <label for="confirmInGameName">In-Game Character Name</label>
        <input type="text" id="confirmInGameName" name="inGameName" placeholder="Your character name" />

        <label for="confirmMeetingPoint">Preferred Meeting Point</label>
        <input type="text" id="confirmMeetingPoint" name="meetingPoint" placeholder="e.g. Firelink Shrine" />

        <label for="confirmAdditionalInfo">Additional Information</label>
        <textarea id="confirmAdditionalInfo" name="additionalInfo" placeholder="Timezone, availability, etc."></textarea>

        <div class="confirm-warning">
          <strong>This action is final.</strong> Once both parties confirm, the trade is marked as completed and cannot be undone. Please ensure you have completed the in-game trade before confirming.
          <br><br>You must have a Discord name set in your <a href="/profile" style="color:var(--warning); text-decoration:underline;">profile</a> before confirming.
        </div>

        <div class="confirm-modal-actions">
          <button type="button" class="btn btn-danger" onclick="closeConfirmModal()">Cancel</button>
          <button type="submit" class="btn btn-success">Confirm Trade</button>
        </div>
      </form>
    </div>
  </div>

  <%- include('partials/auth-modals') %>
  <%- include('partials/footer') %>
  <script src="/js/auth.js"></script>
  <script src="/js/user-hover.js"></script>
  <script>
    function openConfirmModal(tradeId, role) {
      const modal = document.getElementById('confirmTradeModal');
      const form = document.getElementById('confirmTradeForm');
      form.action = '/trade/confirm/' + tradeId;
      modal.classList.add('active');
    }
    function closeConfirmModal() {
      document.getElementById('confirmTradeModal').classList.remove('active');
    }
    // Close on overlay click
    document.getElementById('confirmTradeModal').addEventListener('click', function(e) {
      if (e.target === this) closeConfirmModal();
    });
    // Close on Escape
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeConfirmModal();
    });
  </script>
</body>
</html>
