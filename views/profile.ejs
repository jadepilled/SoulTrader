<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= profileUser.username %> | SoulTrader</title>
  <link rel="icon" type="image/png" href="/icons/favicon.png">
  <link href="https://fonts.googleapis.com/css2?family=Spectral:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/responsive.css">
  <%
    // Helper for display role tinting (used in head style + body)
    function hexToRgb(hex) {
      const result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
      return result ? `${parseInt(result[1],16)},${parseInt(result[2],16)},${parseInt(result[3],16)}` : '255,255,255';
    }
  %>
  <% if (typeof resolvedDisplayRole !== 'undefined' && resolvedDisplayRole) { %>
    <style>
      .profile-section {
        border-color: rgba(<%= hexToRgb(resolvedDisplayRole.color) %>, 0.15) !important;
        box-shadow: inset 0 0 40px rgba(<%= hexToRgb(resolvedDisplayRole.color) %>, 0.02) !important;
        background: rgba(<%= hexToRgb(resolvedDisplayRole.color) %>, 0.025) !important;
      }
    </style>
  <% } %>
</head>
<body>
  <%- include('partials/navbar', { title: profileUser.username + "'s Profile", gameKey: '', pendingTradeCount: typeof pendingTradeCount !== 'undefined' ? pendingTradeCount : 0 }) %>

  <div class="main-content">
    <%- include('partials/flash-messages') %>

    <!-- Profile Header Card -->
    <%
      // Compute theme tint from display role
      const _displayRole = typeof resolvedDisplayRole !== 'undefined' ? resolvedDisplayRole : null;
      const _themeTint = _displayRole ? _displayRole.color : null;
      const _tintRgb = _themeTint ? hexToRgb(_themeTint) : null;
      const _headerStyle = _tintRgb
        ? `border-color: rgba(${_tintRgb}, 0.2); box-shadow: 0 1rem 2.2rem rgba(0,0,0,0.26), inset 0 0 60px rgba(${_tintRgb}, 0.04); background: rgba(${_tintRgb}, 0.03);`
        : '';
      const _sectionStyle = _tintRgb
        ? `border-color: rgba(${_tintRgb}, 0.15); box-shadow: inset 0 0 40px rgba(${_tintRgb}, 0.02); background: rgba(${_tintRgb}, 0.025);`
        : '';
    %>
    <div class="profile-header" style="<%= _headerStyle %>">
      <div class="profile-avatar-col">
        <img
          src="<%= profileUser.profileImagePath || '/images/default-avatar.svg' %>"
          alt="<%= profileUser.username %>"
          class="profile-avatar"
          onerror="this.src='/images/default-avatar.svg'"
        />
        <% if (isOwnProfile) { %>
          <form action="/profile/upload-image" method="POST" enctype="multipart/form-data" class="avatar-upload-form">
            <input
              type="file"
              id="profileImage"
              name="profileImage"
              accept="image/jpeg,image/png,image/webp,image/gif"
              class="avatar-file-input"
            />
            <button type="submit" class="btn btn-primary btn-sm" style="width:100%; margin-top:0.25rem; font-size:0.7rem; padding:0.25rem 0.5rem;">Upload</button>
          </form>
        <% } %>
      </div>

      <div class="profile-info">
        <h1 style="<%= getUsernameStyle(profileUser.role) %>"><%= profileUser.username %></h1>
        <div class="profile-role" <% if (_displayRole) { %>style="color: <%= _displayRole.color %>;"<% } %>>
          <%= _displayRole ? _displayRole.name : (profileUser.role === 'super_admin' ? 'Super Admin' : profileUser.role) %>
        </div>
        <div class="profile-member-since">
          Member since <%= profileUser.createdAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long' }) %>
          <% if (profileUser.lastOnline) { %>
            <span style="margin-left: 0.75rem; color: var(--text-muted); font-size: 0.82rem;">
              <%
                const _now = new Date();
                const _last = new Date(profileUser.lastOnline);
                const _diffMs = _now - _last;
                const _diffMin = Math.floor(_diffMs / 60000);
                let _lastOnlineStr;
                if (_diffMin < 3)       _lastOnlineStr = 'Online now';
                else if (_diffMin < 60) _lastOnlineStr = 'Last seen ' + _diffMin + 'm ago';
                else if (_diffMin < 1440) _lastOnlineStr = 'Last seen ' + Math.floor(_diffMin / 60) + 'h ago';
                else                     _lastOnlineStr = 'Last seen ' + Math.floor(_diffMin / 1440) + 'd ago';
              %>
              <% if (_diffMin < 3) { %>
                <span style="color: var(--success);">&#9679;</span>
              <% } %>
              <%= _lastOnlineStr %>
            </span>
          <% } %>
        </div>

        <!-- Stats -->
        <div class="profile-stats">
          <div class="profile-stat">
            <div class="stat-value" style="color: <%= totalKarma >= 0 ? 'var(--success)' : 'var(--danger)' %>;">
              <%= totalKarma >= 0 ? '+' : '' %><%= totalKarma %>
            </div>
            <div class="stat-label">Karma</div>
          </div>
          <div class="profile-stat">
            <div class="stat-value" style="color: var(--success);"><%= profileUser.positiveKarma %></div>
            <div class="stat-label">Positive</div>
          </div>
          <div class="profile-stat">
            <div class="stat-value" style="color: var(--danger);"><%= profileUser.negativeKarma %></div>
            <div class="stat-label">Negative</div>
          </div>
          <div class="profile-stat">
            <%
              // Smooth color interpolation: 0-40% red, 40-70% yellow, 70-100% green
              const pct = parseInt(positivePercent, 10) || 0;
              let ratingColor;
              if (pct <= 40) {
                ratingColor = '#ef4444'; // red
              } else if (pct <= 55) {
                const t = (pct - 40) / 15;
                const r = Math.round(239 + t * (234 - 239));
                const g = Math.round(68 + t * (179 - 68));
                const b = Math.round(68 + t * (8 - 68));
                ratingColor = `rgb(${r},${g},${b})`;
              } else if (pct <= 75) {
                const t = (pct - 55) / 20;
                const r = Math.round(234 + t * (34 - 234));
                const g = Math.round(179 + t * (197 - 179));
                const b = Math.round(8 + t * (94 - 8));
                ratingColor = `rgb(${r},${g},${b})`;
              } else {
                ratingColor = '#22c55e'; // green
              }
            %>
            <div class="stat-value" style="color: <%= ratingColor %>;"><%= positivePercent %>%</div>
            <div class="stat-label">Rating</div>
          </div>
          <div class="profile-stat">
            <div class="stat-value"><%= completedTradeCount %></div>
            <div class="stat-label">Trades</div>
          </div>
          <div class="profile-stat">
            <div class="stat-value" style="color: var(--text-muted); font-size:0.85em;">
              <%= profileUser.positiveKarma + profileUser.negativeKarma %>
            </div>
            <div class="stat-label">Feedback</div>
          </div>
        </div>

        <!-- Role Badges -->
        <% if (typeof badges !== 'undefined' && badges.length > 0) { %>
          <div class="profile-badges">
            <% badges.forEach(badge => { %>
              <span class="contact-item">
                <span class="contact-platform" style="background:<%= badge.color %>; color:<%= badge.textColor %>"><%= badge.name %></span>
              </span>
            <% }); %>
          </div>
        <% } %>

        <!-- Contact Details & Linked Accounts -->
        <%
          const hasLinked = profileUser.steamUsername || profileUser.discordUsername;
          // For public view, respect privacy settings; own profile always sees everything
          const showDiscord = profileUser.contactDiscord && (isOwnProfile || !profileUser.hideDiscord);
          const showSteam   = profileUser.contactSteam   && (isOwnProfile || !profileUser.hideSteam);
          const showPSN     = profileUser.contactPSN     && (isOwnProfile || !profileUser.hidePSN);
          const showXbox    = profileUser.contactXbox    && (isOwnProfile || !profileUser.hideXbox);
          const hasContact  = showDiscord || showSteam || showPSN || showXbox;
        %>
        <% if (hasLinked || hasContact) { %>
          <div class="profile-badges">
            <% if (profileUser.steamUsername) { %>
              <span class="linked-badge"><strong>Steam:</strong> <%= profileUser.steamUsername %></span>
            <% } %>
            <% if (profileUser.discordUsername) { %>
              <span class="linked-badge"><strong>Discord:</strong> <%= profileUser.discordUsername %></span>
            <% } %>
            <% if (showDiscord) { %>
              <span class="contact-item">
                <span class="contact-platform contact-discord">Discord</span>
                <span class="contact-value"><%= profileUser.contactDiscord %></span>
              </span>
            <% } %>
            <% if (showSteam) { %>
              <span class="contact-item">
                <span class="contact-platform contact-steam">Steam</span>
                <span class="contact-value"><%= profileUser.contactSteam %></span>
              </span>
            <% } %>
            <% if (showPSN) { %>
              <span class="contact-item">
                <span class="contact-platform contact-psn">PSN</span>
                <span class="contact-value"><%= profileUser.contactPSN %></span>
              </span>
            <% } %>
            <% if (showXbox) { %>
              <span class="contact-item">
                <span class="contact-platform contact-xbox">Xbox</span>
                <span class="contact-value"><%= profileUser.contactXbox %></span>
              </span>
            <% } %>
          </div>
        <% } %>

        <!-- Bio -->
        <div class="profile-bio">
          <% if (profileUser.bio) { %>
            <p style="white-space: pre-wrap; margin:0;"><%= profileUser.bio %></p>
          <% } else { %>
            <p style="color: var(--text-muted); font-style:italic; margin:0;">No bio yet.</p>
          <% } %>
        </div>

        <% if (isOwnProfile) { %>
          <button class="profile-edit-toggle" onclick="toggleProfileEdit()">Edit Profile</button>
        <% } else { %>
          <div style="display:flex; gap:0.5rem; flex-wrap:wrap; margin-top:0.75rem;">
            <% if (typeof userId !== 'undefined' && userId && !isBlockedBy && !isBlocked) { %>
              <a href="/messages/<%= profileUser.username %>" class="btn btn-primary btn-sm">Send Message</a>
            <% } %>
            <% if (typeof userId !== 'undefined' && userId) { %>
              <% if (friendshipStatus === 'accepted') { %>
                <button class="btn btn-sm" style="border-color: var(--success); color: var(--success);" onclick="removeFriend('<%= profileUser.username %>')">Remove Friend</button>
              <% } else if (friendshipStatus === 'pending_sent') { %>
                <span class="btn btn-sm" style="border-color: var(--text-muted); color: var(--text-muted); cursor:default; opacity:0.7;">Request Sent</span>
              <% } else if (friendshipStatus === 'pending_received') { %>
                <button class="btn btn-sm" style="border-color: var(--success); color: var(--success);" onclick="acceptFriendRequest('<%= friendshipId %>')">Accept Request</button>
                <button class="btn btn-sm" style="border-color: var(--danger); color: var(--danger);" onclick="declineFriendRequest('<%= friendshipId %>')">Decline</button>
              <% } else if (!isBlocked && !isBlockedBy) { %>
                <button class="btn btn-sm" style="border-color: var(--primary, #c8a84e); color: var(--primary, #c8a84e);" onclick="sendFriendRequest('<%= profileUser.username %>')">Add Friend</button>
              <% } %>
              <% if (!isBlocked) { %>
                <button class="btn btn-sm" style="border-color: var(--danger); color: var(--danger);" onclick="document.getElementById('blockUserPanel').classList.toggle('open')">Block User</button>
              <% } else { %>
                <button class="btn btn-sm" style="border-color: var(--text-muted); color: var(--text-muted);" onclick="unblockUser('<%= profileUser.username %>')">Unblock User</button>
              <% } %>
            <% } %>
            <% if (typeof userId !== 'undefined' && userId && typeof role !== 'undefined') { %>
              <button class="btn btn-sm" style="border-color: var(--danger); color: var(--danger);" onclick="document.getElementById('reportUserPanel').classList.toggle('open')">Report User</button>
            <% } %>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Report User Panel (hidden by default) -->
    <% if (!isOwnProfile && typeof userId !== 'undefined' && userId) { %>
      <div id="reportUserPanel" class="profile-edit-panel">
        <div class="profile-section">
          <h2 class="profile-section-title">Report <%= profileUser.username %></h2>
          <p style="color:var(--text-muted); font-size:0.85rem; margin-bottom:0.75rem;">
            Reports are reviewed by admin staff. Please provide a clear reason.
          </p>
          <form action="/reports/user/<%= profileUser.id %>" method="POST">
            <textarea name="reason" maxlength="500" rows="3" placeholder="Reason for reporting this user..." required style="margin-bottom:0.5rem;"></textarea>
            <div style="display:flex; justify-content:space-between; align-items:center;">
              <span style="font-size:0.72rem; color:var(--text-muted);">Max 500 characters</span>
              <button type="submit" class="btn btn-danger btn-sm">Submit Report</button>
            </div>
          </form>
        </div>
      </div>
    <% } %>

    <!-- Block User Panel (hidden by default) -->
    <% if (!isOwnProfile && typeof userId !== 'undefined' && userId && !isBlocked) { %>
      <div id="blockUserPanel" class="profile-edit-panel">
        <div class="profile-section">
          <h2 class="profile-section-title">Block <%= profileUser.username %></h2>
          <p style="color:var(--text-muted); font-size:0.85rem; margin-bottom:0.75rem;">
            Blocking this user will prevent them from messaging you and remove any existing friendship. This can be undone later.
          </p>
          <p style="color:var(--text-muted); font-size:0.85rem; margin-bottom:0.75rem;">
            Would you also like to report this user? (optional)
          </p>
          <textarea id="blockReportReason" maxlength="500" rows="3" placeholder="Reason for report (optional)..." style="margin-bottom:0.5rem;"></textarea>
          <div style="display:flex; justify-content:flex-end; gap:0.5rem;">
            <button type="button" class="btn btn-secondary btn-sm" onclick="document.getElementById('blockUserPanel').classList.remove('open')">Cancel</button>
            <button type="button" class="btn btn-danger btn-sm" onclick="blockUser('<%= profileUser.username %>')">Block User</button>
          </div>
        </div>
      </div>
    <% } %>

    <!-- Pending Friend Requests (own profile only) -->
    <% if (isOwnProfile && typeof pendingFriendRequests !== 'undefined' && pendingFriendRequests.length > 0) { %>
      <div class="profile-section" style="<%= _sectionStyle %>">
        <h2 class="profile-section-title">Friend Requests (<%= pendingFriendRequests.length %>)</h2>
        <div style="display:flex; flex-direction:column; gap:0.5rem;">
          <% pendingFriendRequests.forEach(fr => { %>
            <div style="display:flex; align-items:center; gap:0.75rem; padding:0.5rem 0.75rem; background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.08); border-radius:var(--radius);" id="fr-<%= fr.id %>">
              <% if (fr.requester && fr.requester.profileImagePath) { %>
                <img src="<%= fr.requester.profileImagePath %>" style="width:32px;height:32px;border-radius:50%;object-fit:cover;" alt="" onerror="this.style.display='none'">
              <% } else { %>
                <div style="width:32px;height:32px;border-radius:50%;background:rgba(255,255,255,0.08);display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:700;color:var(--text-muted);"><%= fr.requester ? fr.requester.username.charAt(0).toUpperCase() : '?' %></div>
              <% } %>
              <a href="/profile/<%= fr.requester ? fr.requester.username : '' %>" style="<%= fr.requester ? getUsernameStyle(fr.requester.role) : '' %>; font-weight:700; text-decoration:none; flex:1;"><%= fr.requester ? fr.requester.username : 'Unknown' %></a>
              <button class="btn btn-success btn-sm" onclick="acceptFriendRequest('<%= fr.id %>')">Accept</button>
              <button class="btn btn-danger btn-sm" onclick="declineFriendRequest('<%= fr.id %>')">Decline</button>
            </div>
          <% }); %>
        </div>
      </div>
    <% } %>

    <!-- Friends List -->
    <% if (typeof friendsList !== 'undefined' && friendsList.length > 0) { %>
      <div class="profile-section" style="<%= _sectionStyle %>">
        <h2 class="profile-section-title">Friends (<%= friendsList.length %>)</h2>
        <div style="display:flex; flex-wrap:wrap; gap:0.75rem;">
          <% friendsList.forEach(friend => { %>
            <a href="/profile/<%= friend.username %>" style="display:flex; align-items:center; gap:0.5rem; padding:0.4rem 0.75rem; background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:999px; text-decoration:none; transition:border-color 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)'">
              <% if (friend.profileImagePath) { %>
                <img src="<%= friend.profileImagePath %>" style="width:24px;height:24px;border-radius:50%;object-fit:cover;" alt="" onerror="this.style.display='none'">
              <% } else { %>
                <div style="width:24px;height:24px;border-radius:50%;background:rgba(255,255,255,0.08);display:flex;align-items:center;justify-content:center;font-size:0.6rem;font-weight:700;color:var(--text-muted);"><%= friend.username.charAt(0).toUpperCase() %></div>
              <% } %>
              <span style="<%= getUsernameStyle(friend.role) %>; font-size:0.82rem; font-weight:600;"><%= friend.username %></span>
            </a>
          <% }); %>
        </div>
      </div>
    <% } %>

    <!-- Edit Panel (hidden by default, own profile only) -->
    <% if (isOwnProfile) { %>
      <div id="profileEditPanel" class="profile-edit-panel">
        <div class="profile-section">
          <h2 class="profile-section-title">Edit Profile</h2>

          <!-- Bio -->
          <form action="/profile/update" method="POST" style="margin-bottom:2rem;">
            <label for="bio">Bio <span style="color:var(--text-muted); font-size:0.8rem;">(max 500 characters)</span></label>
            <textarea id="bio" name="bio" maxlength="500" style="margin-top:0.5rem;"><%= profileUser.bio || '' %></textarea>
            <button type="submit" class="btn btn-primary btn-sm" style="margin-top:0.5rem;">Save Bio</button>
          </form>

          <!-- Contact Details -->
          <form action="/profile/update-contact" method="POST" style="margin-bottom:2rem;">
            <h3 class="profile-subsection-title">Contact Details</h3>
            <p style="color:var(--text-muted); font-size:0.85rem; margin-bottom:0.5rem;">
              These help trade partners reach you. Use the Privacy Options below to control which are publicly visible.
            </p>
            <p style="color:var(--accent, #c8a84e); font-size:0.78rem; margin-bottom:1rem; font-style:italic;">
              Your Discord name is required for trading and will be shared with anyone you agree to trade with.
            </p>

            <div class="contact-edit-grid">
              <div class="contact-edit-field">
                <label for="contactDiscord">
                  <span class="contact-platform contact-discord" style="font-size:0.75rem;">Discord</span>
                </label>
                <input
                  type="text"
                  id="contactDiscord"
                  name="contactDiscord"
                  maxlength="100"
                  placeholder="e.g. username or username#0000"
                  value="<%= profileUser.contactDiscord || '' %>"
                  style="margin-top:0.35rem;"
                />
              </div>
              <div class="contact-edit-field">
                <label for="contactSteam">
                  <span class="contact-platform contact-steam" style="font-size:0.75rem;">Steam</span>
                </label>
                <input
                  type="text"
                  id="contactSteam"
                  name="contactSteam"
                  maxlength="200"
                  placeholder="e.g. Steam username or profile URL"
                  value="<%= profileUser.contactSteam || '' %>"
                  style="margin-top:0.35rem;"
                />
              </div>
              <div class="contact-edit-field">
                <label for="contactPSN">
                  <span class="contact-platform contact-psn" style="font-size:0.75rem;">PSN</span>
                </label>
                <input
                  type="text"
                  id="contactPSN"
                  name="contactPSN"
                  maxlength="100"
                  placeholder="e.g. YourPSNID"
                  value="<%= profileUser.contactPSN || '' %>"
                  style="margin-top:0.35rem;"
                />
              </div>
              <div class="contact-edit-field">
                <label for="contactXbox">
                  <span class="contact-platform contact-xbox" style="font-size:0.75rem;">Xbox</span>
                </label>
                <input
                  type="text"
                  id="contactXbox"
                  name="contactXbox"
                  maxlength="100"
                  placeholder="e.g. YourGamertag"
                  value="<%= profileUser.contactXbox || '' %>"
                  style="margin-top:0.35rem;"
                />
              </div>
            </div>
            <button type="submit" class="btn btn-primary btn-sm" style="margin-top:1rem;">Save Contact Details</button>
          </form>

          <!-- Timezone -->
          <form action="/profile/update-timezone" method="POST" style="margin-bottom:2rem;">
            <h3 class="profile-subsection-title">Timezone</h3>
            <p style="color:var(--text-muted); font-size:0.85rem; margin-bottom:0.5rem;">
              Set your timezone to help coordinate trades. Required before creating trades.
            </p>
            <select name="timezone" id="timezoneSelect" style="margin-bottom:0.5rem;">
              <option value="">Select timezone...</option>
              <%
                const tzOptions = [
                  'UTC-12:00 (Baker Island)', 'UTC-11:00 (Samoa)', 'UTC-10:00 (Hawaii)',
                  'UTC-09:00 (Alaska)', 'UTC-08:00 (Pacific Time)', 'UTC-07:00 (Mountain Time)',
                  'UTC-06:00 (Central Time)', 'UTC-05:00 (Eastern Time)', 'UTC-04:00 (Atlantic Time)',
                  'UTC-03:00 (Argentina, Brazil)', 'UTC-02:00 (South Georgia)', 'UTC-01:00 (Azores)',
                  'UTC+00:00 (GMT/London)', 'UTC+01:00 (CET/Paris/Berlin)',
                  'UTC+02:00 (EET/Cairo/Helsinki)', 'UTC+03:00 (Moscow/Istanbul)',
                  'UTC+04:00 (Dubai/Baku)', 'UTC+05:00 (Pakistan/Uzbekistan)',
                  'UTC+05:30 (India)', 'UTC+06:00 (Bangladesh/Almaty)',
                  'UTC+07:00 (Bangkok/Jakarta)', 'UTC+08:00 (Singapore/Perth/Beijing)',
                  'UTC+09:00 (Tokyo/Seoul)', 'UTC+09:30 (Adelaide)',
                  'UTC+10:00 (Sydney/Melbourne)', 'UTC+11:00 (Solomon Islands)',
                  'UTC+12:00 (Auckland/Fiji)', 'UTC+13:00 (Tonga)',
                ];
              %>
              <% tzOptions.forEach(tz => { %>
                <option value="<%= tz %>" <%= (profileUser.timezone === tz) ? 'selected' : '' %>><%= tz %></option>
              <% }); %>
            </select>
            <label class="privacy-checkbox" style="margin-top:0.5rem;">
              <input type="checkbox" name="hideTimezone" <%= profileUser.hideTimezone !== false ? 'checked' : '' %> />
              <span>Hide timezone from public profile</span>
            </label>
            <button type="submit" class="btn btn-primary btn-sm" style="margin-top:0.75rem;">Save Timezone</button>
          </form>

          <!-- Privacy Options -->
          <form action="/profile/update-privacy" method="POST" style="margin-bottom:2rem;">
            <h3 class="profile-subsection-title">Privacy Options</h3>
            <p style="color:var(--text-muted); font-size:0.85rem; margin-bottom:0.75rem;">
              Choose which contact details to hide from your public profile. Hidden contacts are still shared with trade partners when you agree to a trade.
            </p>
            <div class="privacy-options-grid">
              <label class="privacy-checkbox">
                <input type="checkbox" name="hideDiscord" <%= profileUser.hideDiscord ? 'checked' : '' %> />
                <span>Hide Discord from profile</span>
              </label>
              <label class="privacy-checkbox">
                <input type="checkbox" name="hideSteam" <%= profileUser.hideSteam ? 'checked' : '' %> />
                <span>Hide Steam from profile</span>
              </label>
              <label class="privacy-checkbox">
                <input type="checkbox" name="hidePSN" <%= profileUser.hidePSN ? 'checked' : '' %> />
                <span>Hide PSN from profile</span>
              </label>
              <label class="privacy-checkbox">
                <input type="checkbox" name="hideXbox" <%= profileUser.hideXbox ? 'checked' : '' %> />
                <span>Hide Xbox from profile</span>
              </label>
            </div>
            <p style="color:var(--text-muted); font-size:0.78rem; margin-top:0.5rem; font-style:italic;">
              Note: Your Discord name will always be shared with anyone you agree to trade with, so they can contact you to coordinate the trade.
            </p>
            <button type="submit" class="btn btn-primary btn-sm" style="margin-top:0.75rem;">Save Privacy Settings</button>
          </form>

          <!-- Display Role / Profile Theme -->
          <% if (typeof availableDisplayRoles !== 'undefined' && availableDisplayRoles.length > 0) { %>
            <form action="/profile/update-display-role" method="POST" style="margin-bottom:2rem;">
              <h3 class="profile-subsection-title">Profile Theme</h3>
              <p style="color:var(--text-muted); font-size:0.85rem; margin-bottom:0.75rem;">
                Choose a display role to theme your profile. This replaces the role label beneath your name and tints your profile with that role's colour.
              </p>
              <div class="display-role-options">
                <label class="display-role-option">
                  <input type="radio" name="displayRole" value="none" <%= !profileUser.displayRole ? 'checked' : '' %> />
                  <span class="display-role-chip" style="background: rgba(255,255,255,0.06); color: var(--text-muted);">Default</span>
                </label>
                <% availableDisplayRoles.forEach(dr => { %>
                  <label class="display-role-option">
                    <input type="radio" name="displayRole" value="<%= dr.value %>" <%= profileUser.displayRole === dr.value ? 'checked' : '' %> />
                    <span class="display-role-chip" style="background: <%= dr.color %>20; color: <%= dr.color %>; border-color: <%= dr.color %>40;"><%= dr.name %></span>
                  </label>
                <% }); %>
              </div>
              <button type="submit" class="btn btn-primary btn-sm" style="margin-top:0.75rem;">Save Theme</button>
            </form>
          <% } %>

          <!-- Verified Accounts -->
          <h3 class="profile-subsection-title">Verified Accounts</h3>
          <p style="color:var(--text-muted); font-size:0.85rem; margin-bottom:1rem;">
            Link your Steam or Discord to verify your identity. Each account can only be linked to one SoulTrader profile.
          </p>
          <div style="display:flex; gap:0.75rem; flex-wrap:wrap;">
            <% if (!profileUser.steamId) { %>
              <a href="/auth/steam" class="btn btn-sm">Link Steam</a>
            <% } else { %>
              <div style="display:flex; align-items:center; gap:0.5rem;">
                <span class="linked-badge">Steam: <%= profileUser.steamUsername %></span>
                <form id="unlink-steam-form" action="/auth/unlink/steam" method="POST" style="display:inline;">
                  <button type="button" class="btn btn-danger btn-sm" onclick="showStyledConfirm('Unlink your Steam account?', () => { document.getElementById('unlink-steam-form').submit(); })">Unlink</button>
                </form>
              </div>
            <% } %>

            <% if (!profileUser.discordId) { %>
              <a href="/auth/discord" class="btn btn-sm">Link Discord</a>
            <% } else { %>
              <div style="display:flex; align-items:center; gap:0.5rem;">
                <span class="linked-badge">Discord: <%= profileUser.discordUsername %></span>
                <form id="unlink-discord-form" action="/auth/unlink/discord" method="POST" style="display:inline;">
                  <button type="button" class="btn btn-danger btn-sm" onclick="showStyledConfirm('Unlink your Discord account?', () => { document.getElementById('unlink-discord-form').submit(); })">Unlink</button>
                </form>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    <% } %>

    <!-- Profile Comments -->
    <div class="profile-section">
      <h2 class="profile-section-title">Comments (<%= typeof totalComments !== 'undefined' ? totalComments : 0 %>)</h2>

      <% if (typeof query !== 'undefined' && query.error) { %>
        <p style="color:var(--danger); font-size:0.85rem; margin-bottom:1rem;"><%= query.error %></p>
      <% } %>

      <!-- Comment form (logged-in users only) -->
      <% if (typeof userId !== 'undefined' && userId) { %>
        <form action="/comments/<%= profileUser.id %>" method="POST" class="comment-form">
          <textarea name="content" id="commentTextarea" maxlength="200" rows="3" placeholder="Leave a comment..." required></textarea>
          <div style="display:flex; justify-content:space-between; align-items:center; margin-top:0.5rem;">
            <span id="commentCharCounter" style="font-size:0.72rem; color:var(--text-muted);">0/200</span>
            <button type="submit" class="btn btn-primary btn-sm">Post</button>
          </div>
        </form>
      <% } else { %>
        <p style="color:var(--text-muted); font-size:0.85rem; font-style:italic;">Log in to leave a comment.</p>
      <% } %>

      <!-- Comment list -->
      <div class="comment-list">
        <% if (typeof comments !== 'undefined' && comments.length > 0) { %>
          <% comments.forEach(comment => { %>
            <div class="comment-card" id="comment-<%= comment.id %>">
              <div class="comment-header">
                <div class="comment-author">
                  <% if (comment.author && comment.author.profileImagePath) { %>
                    <img src="<%= comment.author.profileImagePath %>" class="comment-avatar" alt="" onerror="this.style.display='none'">
                  <% } else { %>
                    <div class="comment-avatar-fallback"><%= comment.author ? comment.author.username.charAt(0).toUpperCase() : '?' %></div>
                  <% } %>
                  <a href="/profile/<%= comment.author ? comment.author.username : '' %>"
                     class="comment-author-name"
                     style="<%= comment.author ? getUsernameStyle(comment.author.role) : '' %>">
                    <%= comment.author ? comment.author.username : 'Unknown' %>
                  </a>
                </div>
                <div class="comment-meta">
                  <span class="comment-date"><%= comment.createdAt.toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' }) %></span>
                  <% if (comment.editedAt) { %>
                    <span class="comment-edited">(edited)</span>
                  <% } %>
                </div>
              </div>
              <div class="comment-body" id="comment-body-<%= comment.id %>"><%= comment.content %></div>
              <div class="comment-actions">
                <% const canEdit   = typeof userId !== 'undefined' && userId && comment.author && comment.authorId === userId; %>
                <% const canDelete = typeof userId !== 'undefined' && userId && (comment.authorId === userId || profileUser.id === userId || role === 'admin' || role === 'super_admin'); %>
                <% if (canEdit) { %>
                  <button class="comment-action-btn" onclick="editComment('<%= comment.id %>')">Edit</button>
                <% } %>
                <% if (canDelete) { %>
                  <button class="comment-action-btn comment-delete-btn" onclick="deleteComment('<%= comment.id %>')">Delete</button>
                <% } %>
              </div>
            </div>
          <% }); %>
        <% } else { %>
          <p style="color:var(--text-muted); font-style:italic; margin-top:1rem;">No comments yet.</p>
        <% } %>
      </div>

      <!-- Comment pagination -->
      <% if (typeof totalCommentPages !== 'undefined' && totalCommentPages > 1) { %>
        <div class="pagination" style="margin-top:1rem;">
          <% for (let i = 1; i <= totalCommentPages; i++) { %>
            <a href="/profile/<%= profileUser.username %>?commentPage=<%= i %>"
               class="pagination-btn <%= (typeof commentPage !== 'undefined' ? commentPage : 1) === i ? 'active' : '' %>"><%= i %></a>
          <% } %>
        </div>
      <% } %>
    </div>

    <!-- Trade Feedback -->
    <% if (typeof feedbackItems !== 'undefined' && feedbackItems.length > 0) { %>
      <div class="profile-section">
        <h2 class="profile-section-title">Trade Feedback (<%= feedbackItems.length %>)</h2>
        <div class="comment-list">
          <% feedbackItems.forEach(fb => { %>
            <%
              // Color feedback card based on rating: 1-3 red, 4-5 yellow, 6-7 neutral, 8-10 green
              let fbBorderColor, fbBgColor, fbAvatarBg, fbAvatarColor, fbLabel;
              const r = fb.rating;
              if (!r || r >= 8) {
                fbBorderColor = 'rgba(34, 197, 94, 1)';
                fbBgColor = 'rgba(34, 197, 94, 0.03)';
                fbAvatarBg = 'rgba(34, 197, 94, 0.15)';
                fbAvatarColor = '#22c55e';
              } else if (r >= 6) {
                fbBorderColor = 'rgba(168, 162, 158, 1)';
                fbBgColor = 'rgba(168, 162, 158, 0.03)';
                fbAvatarBg = 'rgba(168, 162, 158, 0.15)';
                fbAvatarColor = '#a8a29e';
              } else if (r >= 4) {
                fbBorderColor = 'rgba(234, 179, 8, 1)';
                fbBgColor = 'rgba(234, 179, 8, 0.03)';
                fbAvatarBg = 'rgba(234, 179, 8, 0.15)';
                fbAvatarColor = '#eab308';
              } else {
                fbBorderColor = 'rgba(239, 68, 68, 1)';
                fbBgColor = 'rgba(239, 68, 68, 0.03)';
                fbAvatarBg = 'rgba(239, 68, 68, 0.15)';
                fbAvatarColor = '#ef4444';
              }
            %>
            <div class="comment-card" style="border-left: 3px solid <%= fbBorderColor %>; background: <%= fbBgColor %>;">
              <div class="comment-header">
                <div class="comment-author">
                  <div class="comment-avatar-fallback" style="background: <%= fbAvatarBg %>; color: <%= fbAvatarColor %>; font-size: 0.6rem;"><%= r ? r + '/10' : 'TF' %></div>
                  <a href="/profile/<%= fb.authorUsername %>"
                     class="comment-author-name"
                     style="<%= getUsernameStyle(fb.authorRole) %>">
                    <%= fb.authorUsername %>
                  </a>
                  <span style="font-size:0.7rem; color:var(--text-muted); margin-left:0.25rem;">via trade</span>
                  <% if (fb.game) { %>
                    <span style="font-size:0.68rem; color:var(--text-muted); opacity:0.7; margin-left:0.25rem;">(<%= fb.game %>)</span>
                  <% } %>
                </div>
                <div class="comment-meta">
                  <span class="comment-date"><%= fb.date.toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' }) %></span>
                </div>
              </div>
              <div class="comment-body"><%= fb.content %></div>
              <% if (typeof role !== 'undefined' && (role === 'admin' || role === 'super_admin')) { %>
                <div class="comment-actions">
                  <button class="comment-action-btn comment-delete-btn" onclick="deleteFeedback('<%= fb.tradeId %>', '<%= fb.party %>')">Remove Feedback</button>
                </div>
              <% } %>
            </div>
          <% }); %>
        </div>
      </div>
    <% } %>

    <!-- Recent Trade History -->
    <div class="profile-section">
      <h2 class="profile-section-title">Recent Trade History</h2>
      <% if (recentTrades && recentTrades.length > 0) { %>
        <% recentTrades.forEach(trade => {
          const offItems = trade.offeredItems || [];
          const reqItems = trade.requestedItems || [];
          const partner = trade.offerCreator && trade.offerCreator.id !== profileUser.id
            ? trade.offerCreator
            : trade.acceptor;
          const partnerName = partner ? partner.username : 'Unknown';
          const partnerRole = partner ? partner.role : 'user';
          const completedDate = trade.updatedAt
            ? trade.updatedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
            : '';
        %>
          <%
            const profileGameColorMap = {
              'Dark Souls':    { color: '#7b86a2', rgb: '123, 134, 162' },
              'Dark Souls 2':  { color: '#8b7eaa', rgb: '139, 126, 170' },
              'Dark Souls 3':  { color: '#6e7fa0', rgb: '110, 127, 160' },
              'Elden Ring':    { color: '#c8a84e', rgb: '200, 168, 78' },
              "Demon's Souls": { color: '#8a8a8a', rgb: '138, 138, 138' },
            };
            const pgc = profileGameColorMap[trade.game] || { color: '#8a8a8a', rgb: '138, 138, 138' };
          %>
          <div class="trade-card">
            <% if (trade.game) { %>
              <div class="trade-card-banner" style="background: rgba(<%= pgc.rgb %>, 0.2); color: <%= pgc.color %>; border-bottom: 1px solid rgba(<%= pgc.rgb %>, 0.3);"><%= trade.gameVariant || trade.game %></div>
            <% } %>
            <div class="offer-heading">
              Trade with
              <span style="<%= getUsernameStyle(partnerRole) %>"><%= partnerName %></span>
              <% if (completedDate) { %>
                <span class="time-ago"><%= completedDate %></span>
              <% } %>
            </div>

            <div class="trade-card-inner">
              <div class="offered-col">
                <h2>Offered</h2>
                <% offItems.forEach(item => {
                  const metaParts = [];
                  const _pq = fmtQty(item.qty); if (_pq) metaParts.push('\u00d7' + _pq);
                  if (item.upgrade !== null && item.upgrade !== undefined) metaParts.push('+' + item.upgrade);
                  const meta = metaParts.join(' ');
                %>
                  <div class="trade-item-row">
                    <% if (item.iconPath) { %>
                      <img class="trade-item-icon" src="<%= item.iconPath %>" alt="" onerror="this.style.display='none'">
                    <% } else { %>
                      <div class="trade-item-icon-fallback"><%= item.name.charAt(0) %></div>
                    <% } %>
                    <span class="trade-item-name"><%= item.name %></span>
                    <% if (meta) { %><span class="trade-item-meta"><%= meta %></span><% } %>
                  </div>
                <% }); %>
              </div>
              <div class="requested-col">
                <h2>Received</h2>
                <% reqItems.forEach(item => {
                  const metaParts = [];
                  const _pq = fmtQty(item.qty); if (_pq) metaParts.push('\u00d7' + _pq);
                  if (item.upgrade !== null && item.upgrade !== undefined) metaParts.push('+' + item.upgrade);
                  const meta = metaParts.join(' ');
                %>
                  <div class="trade-item-row">
                    <% if (item.iconPath) { %>
                      <img class="trade-item-icon" src="<%= item.iconPath %>" alt="" onerror="this.style.display='none'">
                    <% } else { %>
                      <div class="trade-item-icon-fallback"><%= item.name.charAt(0) %></div>
                    <% } %>
                    <span class="trade-item-name"><%= item.name %></span>
                    <% if (meta) { %><span class="trade-item-meta"><%= meta %></span><% } %>
                  </div>
                <% }); %>
              </div>
            </div>
          </div>
        <% }); %>
      <% } else { %>
        <p style="color: var(--text-muted); font-style:italic;">No completed trades yet.</p>
      <% } %>
    </div>
  </div>

  <!-- ═══ Styled Confirm Modal ═══ -->
  <div class="confirm-modal-overlay" id="styledConfirmModal">
    <div class="confirm-modal-box">
      <h3 id="styledConfirmTitle">Confirm</h3>
      <p id="styledConfirmMessage" style="color:var(--text-secondary);margin-bottom:1rem;font-size:0.9rem;"></p>
      <div class="confirm-modal-actions">
        <button type="button" class="btn btn-secondary" onclick="closeStyledConfirm()">Cancel</button>
        <button type="button" class="btn btn-danger" id="styledConfirmYes">Confirm</button>
      </div>
    </div>
  </div>

  <%- include('partials/preloader') %>
  <%- include('partials/auth-modals') %>
  <%- include('partials/footer') %>
  <script src="/js/auth.js"></script>
  <script src="/js/user-hover.js"></script>
  <script>
    // ── Styled Confirm Modal ──
    let _styledConfirmCb = null;
    function showStyledConfirm(message, onConfirm) {
      const modal = document.getElementById('styledConfirmModal');
      document.getElementById('styledConfirmMessage').textContent = message;
      _styledConfirmCb = onConfirm;
      modal.classList.add('active');
    }
    function closeStyledConfirm() {
      document.getElementById('styledConfirmModal').classList.remove('active');
      _styledConfirmCb = null;
    }
    document.getElementById('styledConfirmYes').addEventListener('click', () => {
      if (_styledConfirmCb) _styledConfirmCb();
      closeStyledConfirm();
    });
    document.getElementById('styledConfirmModal').addEventListener('click', function(e) {
      if (e.target === this) closeStyledConfirm();
    });
  </script>
  <script>
    function toggleProfileEdit() {
      document.getElementById('profileEditPanel').classList.toggle('open');
    }

    // Comment character counter
    (function() {
      const ta = document.getElementById('commentTextarea');
      const counter = document.getElementById('commentCharCounter');
      if (ta && counter) {
        ta.addEventListener('input', function() {
          counter.textContent = ta.value.length + '/200';
        });
      }
    })();

    async function editComment(commentId) {
      const bodyEl = document.getElementById('comment-body-' + commentId);
      const current = bodyEl.textContent.trim();
      const newText = prompt('Edit your comment:', current);
      if (newText === null || newText.trim() === current) return;
      if (newText.length > 200) { alert('Comment must be 200 characters or fewer.'); return; }

      try {
        const resp = await fetch('/comments/' + commentId, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ content: newText }),
        });
        const data = await resp.json();
        if (data.success) {
          bodyEl.textContent = data.content;
          // Add (edited) indicator
          const meta = bodyEl.closest('.comment-card').querySelector('.comment-meta');
          if (!meta.querySelector('.comment-edited')) {
            const ed = document.createElement('span');
            ed.className = 'comment-edited';
            ed.textContent = '(edited)';
            meta.appendChild(ed);
          }
        } else {
          alert(data.error || 'Failed to edit comment.');
        }
      } catch { alert('Network error.'); }
    }

    function deleteComment(commentId) {
      showStyledConfirm('Delete this comment?', async () => {
        try {
          const resp = await fetch('/comments/' + commentId, { method: 'DELETE' });
          const data = await resp.json();
          if (data.success) {
            document.getElementById('comment-' + commentId).remove();
          } else {
            alert(data.error || 'Failed to delete comment.');
          }
        } catch { alert('Network error.'); }
      });
    }

    // ── Friend / Block actions ──
    async function sendFriendRequest(username) {
      try {
        const resp = await fetch('/friends/request/' + username, { method: 'POST', headers: { 'Content-Type': 'application/json' } });
        const data = await resp.json();
        if (data.success) { location.reload(); }
        else { alert(data.error || 'Failed to send request.'); }
      } catch { alert('Network error.'); }
    }

    async function acceptFriendRequest(friendshipId) {
      try {
        const resp = await fetch('/friends/accept/' + friendshipId, { method: 'POST', headers: { 'Content-Type': 'application/json' } });
        const data = await resp.json();
        if (data.success) { location.reload(); }
        else { alert(data.error || 'Failed to accept request.'); }
      } catch { alert('Network error.'); }
    }

    async function declineFriendRequest(friendshipId) {
      try {
        const resp = await fetch('/friends/decline/' + friendshipId, { method: 'POST', headers: { 'Content-Type': 'application/json' } });
        const data = await resp.json();
        if (data.success) {
          const el = document.getElementById('fr-' + friendshipId);
          if (el) el.remove();
          else location.reload();
        }
        else { alert(data.error || 'Failed to decline request.'); }
      } catch { alert('Network error.'); }
    }

    function removeFriend(username) {
      showStyledConfirm('Remove ' + username + ' from your friends?', async () => {
        try {
          const resp = await fetch('/friends/remove/' + username, { method: 'POST', headers: { 'Content-Type': 'application/json' } });
          const data = await resp.json();
          if (data.success) { location.reload(); }
          else { alert(data.error || 'Failed to remove friend.'); }
        } catch { alert('Network error.'); }
      });
    }

    function blockUser(username) {
      const reportReason = document.getElementById('blockReportReason')?.value || '';
      showStyledConfirm('Block ' + username + '? They will not be able to message you.', async () => {
        try {
          const resp = await fetch('/friends/block/' + username, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ reportReason }),
          });
          const data = await resp.json();
          if (data.success) { location.reload(); }
          else { alert(data.error || 'Failed to block user.'); }
        } catch { alert('Network error.'); }
      });
    }

    function unblockUser(username) {
      showStyledConfirm('Unblock ' + username + '?', async () => {
        try {
          const resp = await fetch('/friends/unblock/' + username, { method: 'POST', headers: { 'Content-Type': 'application/json' } });
          const data = await resp.json();
          if (data.success) { location.reload(); }
          else { alert(data.error || 'Failed to unblock user.'); }
        } catch { alert('Network error.'); }
      });
    }

    function deleteFeedback(tradeId, party) {
      showStyledConfirm('Remove this trade feedback? This cannot be undone.', async () => {
        try {
          const resp = await fetch('/profile/delete-feedback', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ tradeId, party }),
          });
          const data = await resp.json();
          if (data.success) {
            location.reload();
          } else {
            alert(data.error || 'Failed to remove feedback.');
          }
        } catch { alert('Network error.'); }
      });
    }
  </script>
</body>
</html>
