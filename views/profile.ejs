<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= profileUser.username %> | SoulTrader</title>
  <link rel="icon" type="image/x-icon" href="/icons/favicon.ico">
  <link href="https://fonts.googleapis.com/css2?family=Spectral:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/responsive.css">
</head>
<body>
  <%- include('partials/navbar', { title: profileUser.username + "'s Profile", gameKey: '', pendingTradeCount: typeof pendingTradeCount !== 'undefined' ? pendingTradeCount : 0 }) %>

  <div class="main-content">
    <%- include('partials/flash-messages') %>

    <!-- Profile Header Card -->
    <div class="profile-header">
      <div class="profile-avatar-col">
        <img
          src="<%= profileUser.profileImagePath || '/images/default-avatar.svg' %>"
          alt="<%= profileUser.username %>"
          class="profile-avatar"
          onerror="this.src='/images/default-avatar.svg'"
        />
        <% if (isOwnProfile) { %>
          <form action="/profile/upload-image" method="POST" enctype="multipart/form-data" class="avatar-upload-form">
            <input
              type="file"
              id="profileImage"
              name="profileImage"
              accept="image/jpeg,image/png,image/webp,image/gif"
              class="avatar-file-input"
            />
            <button type="submit" class="btn btn-primary btn-sm" style="width:100%; margin-top:0.25rem; font-size:0.7rem; padding:0.25rem 0.5rem;">Upload</button>
          </form>
        <% } %>
      </div>

      <div class="profile-info">
        <h1 style="<%= getUsernameStyle(profileUser.role) %>"><%= profileUser.username %></h1>
        <div class="profile-role"><%= profileUser.role %></div>
        <div class="profile-member-since">
          Member since <%= profileUser.createdAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long' }) %>
        </div>

        <!-- Stats -->
        <div class="profile-stats">
          <div class="profile-stat">
            <div class="stat-value" style="color: <%= totalKarma >= 0 ? 'var(--success)' : 'var(--danger)' %>;">
              <%= totalKarma >= 0 ? '+' : '' %><%= totalKarma %>
            </div>
            <div class="stat-label">Karma</div>
          </div>
          <div class="profile-stat">
            <div class="stat-value" style="color: var(--success);"><%= profileUser.positiveKarma %></div>
            <div class="stat-label">Positive</div>
          </div>
          <div class="profile-stat">
            <div class="stat-value" style="color: var(--danger);"><%= profileUser.negativeKarma %></div>
            <div class="stat-label">Negative</div>
          </div>
          <div class="profile-stat">
            <div class="stat-value"><%= positivePercent %>%</div>
            <div class="stat-label">Rating</div>
          </div>
          <div class="profile-stat">
            <div class="stat-value"><%= completedTradeCount %></div>
            <div class="stat-label">Trades</div>
          </div>
          <div class="profile-stat">
            <div class="stat-value" style="color: var(--text-muted); font-size:0.85em;">
              <%= profileUser.positiveKarma + profileUser.negativeKarma %>
            </div>
            <div class="stat-label">Feedback</div>
          </div>
        </div>

        <!-- Role Badges -->
        <% if (typeof badges !== 'undefined' && badges.length > 0) { %>
          <div class="profile-badges">
            <% badges.forEach(badge => { %>
              <span class="contact-item">
                <span class="contact-platform" style="background:<%= badge.color %>; color:<%= badge.textColor %>"><%= badge.name %></span>
              </span>
            <% }); %>
          </div>
        <% } %>

        <!-- Contact Details & Linked Accounts -->
        <%
          const hasLinked = profileUser.steamUsername || profileUser.discordUsername;
          const hasContact = profileUser.contactDiscord || profileUser.contactSteam ||
                             profileUser.contactPSN || profileUser.contactXbox;
        %>
        <% if (hasLinked || hasContact) { %>
          <div class="profile-badges">
            <% if (profileUser.steamUsername) { %>
              <span class="linked-badge"><strong>Steam:</strong> <%= profileUser.steamUsername %></span>
            <% } %>
            <% if (profileUser.discordUsername) { %>
              <span class="linked-badge"><strong>Discord:</strong> <%= profileUser.discordUsername %></span>
            <% } %>
            <% if (profileUser.contactDiscord) { %>
              <span class="contact-item">
                <span class="contact-platform contact-discord">Discord</span>
                <span class="contact-value"><%= profileUser.contactDiscord %></span>
              </span>
            <% } %>
            <% if (profileUser.contactSteam) { %>
              <span class="contact-item">
                <span class="contact-platform contact-steam">Steam</span>
                <span class="contact-value"><%= profileUser.contactSteam %></span>
              </span>
            <% } %>
            <% if (profileUser.contactPSN) { %>
              <span class="contact-item">
                <span class="contact-platform contact-psn">PSN</span>
                <span class="contact-value"><%= profileUser.contactPSN %></span>
              </span>
            <% } %>
            <% if (profileUser.contactXbox) { %>
              <span class="contact-item">
                <span class="contact-platform contact-xbox">Xbox</span>
                <span class="contact-value"><%= profileUser.contactXbox %></span>
              </span>
            <% } %>
          </div>
        <% } %>

        <!-- Bio -->
        <div class="profile-bio">
          <% if (profileUser.bio) { %>
            <p style="white-space: pre-wrap; margin:0;"><%= profileUser.bio %></p>
          <% } else { %>
            <p style="color: var(--text-muted); font-style:italic; margin:0;">No bio yet.</p>
          <% } %>
        </div>

        <% if (isOwnProfile) { %>
          <button class="profile-edit-toggle" onclick="toggleProfileEdit()">Edit Profile</button>
        <% } %>
      </div>
    </div>

    <!-- Edit Panel (hidden by default, own profile only) -->
    <% if (isOwnProfile) { %>
      <div id="profileEditPanel" class="profile-edit-panel">
        <div class="profile-section">
          <h2 class="profile-section-title">Edit Profile</h2>

          <!-- Bio -->
          <form action="/profile/update" method="POST" style="margin-bottom:2rem;">
            <label for="bio">Bio <span style="color:var(--text-muted); font-size:0.8rem;">(max 500 characters)</span></label>
            <textarea id="bio" name="bio" maxlength="500" style="margin-top:0.5rem;"><%= profileUser.bio || '' %></textarea>
            <button type="submit" class="btn btn-primary btn-sm" style="margin-top:0.5rem;">Save Bio</button>
          </form>

          <!-- Contact Details -->
          <form action="/profile/update-contact" method="POST" style="margin-bottom:2rem;">
            <h3 class="profile-subsection-title">Contact Details</h3>
            <p style="color:var(--text-muted); font-size:0.85rem; margin-bottom:1rem;">
              These are shown publicly on your profile so trade partners know how to reach you.
            </p>

            <div class="contact-edit-grid">
              <div class="contact-edit-field">
                <label for="contactDiscord">
                  <span class="contact-platform contact-discord" style="font-size:0.75rem;">Discord</span>
                </label>
                <input
                  type="text"
                  id="contactDiscord"
                  name="contactDiscord"
                  maxlength="100"
                  placeholder="e.g. username or username#0000"
                  value="<%= profileUser.contactDiscord || '' %>"
                  style="margin-top:0.35rem;"
                />
              </div>
              <div class="contact-edit-field">
                <label for="contactSteam">
                  <span class="contact-platform contact-steam" style="font-size:0.75rem;">Steam</span>
                </label>
                <input
                  type="text"
                  id="contactSteam"
                  name="contactSteam"
                  maxlength="200"
                  placeholder="e.g. Steam username or profile URL"
                  value="<%= profileUser.contactSteam || '' %>"
                  style="margin-top:0.35rem;"
                />
              </div>
              <div class="contact-edit-field">
                <label for="contactPSN">
                  <span class="contact-platform contact-psn" style="font-size:0.75rem;">PSN</span>
                </label>
                <input
                  type="text"
                  id="contactPSN"
                  name="contactPSN"
                  maxlength="100"
                  placeholder="e.g. YourPSNID"
                  value="<%= profileUser.contactPSN || '' %>"
                  style="margin-top:0.35rem;"
                />
              </div>
              <div class="contact-edit-field">
                <label for="contactXbox">
                  <span class="contact-platform contact-xbox" style="font-size:0.75rem;">Xbox</span>
                </label>
                <input
                  type="text"
                  id="contactXbox"
                  name="contactXbox"
                  maxlength="100"
                  placeholder="e.g. YourGamertag"
                  value="<%= profileUser.contactXbox || '' %>"
                  style="margin-top:0.35rem;"
                />
              </div>
            </div>
            <button type="submit" class="btn btn-primary btn-sm" style="margin-top:1rem;">Save Contact Details</button>
          </form>

          <!-- Verified Accounts -->
          <h3 class="profile-subsection-title">Verified Accounts</h3>
          <p style="color:var(--text-muted); font-size:0.85rem; margin-bottom:1rem;">
            Link your Steam or Discord to verify your identity. Each account can only be linked to one SoulTrader profile.
          </p>
          <div style="display:flex; gap:0.75rem; flex-wrap:wrap;">
            <% if (!profileUser.steamId) { %>
              <a href="/auth/steam" class="btn btn-sm">Link Steam</a>
            <% } else { %>
              <div style="display:flex; align-items:center; gap:0.5rem;">
                <span class="linked-badge">Steam: <%= profileUser.steamUsername %></span>
                <form action="/auth/unlink/steam" method="POST" style="display:inline;">
                  <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Unlink Steam account?')">Unlink</button>
                </form>
              </div>
            <% } %>

            <% if (!profileUser.discordId) { %>
              <a href="/auth/discord" class="btn btn-sm">Link Discord</a>
            <% } else { %>
              <div style="display:flex; align-items:center; gap:0.5rem;">
                <span class="linked-badge">Discord: <%= profileUser.discordUsername %></span>
                <form action="/auth/unlink/discord" method="POST" style="display:inline;">
                  <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Unlink Discord account?')">Unlink</button>
                </form>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    <% } %>

    <!-- Recent Trade History -->
    <div class="profile-section">
      <h2 class="profile-section-title">Recent Trade History</h2>
      <% if (recentTrades && recentTrades.length > 0) { %>
        <% recentTrades.forEach(trade => {
          const offItems = trade.offeredItems || [];
          const reqItems = trade.requestedItems || [];
          const partner = trade.offerCreator && trade.offerCreator.id !== profileUser.id
            ? trade.offerCreator
            : trade.acceptor;
          const partnerName = partner ? partner.username : 'Unknown';
          const partnerRole = partner ? partner.role : 'user';
          const completedDate = trade.updatedAt
            ? trade.updatedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
            : '';
        %>
          <%
            const profileGameColorMap = {
              'Dark Souls':    { color: '#7b86a2', rgb: '123, 134, 162' },
              'Dark Souls 2':  { color: '#8b7eaa', rgb: '139, 126, 170' },
              'Dark Souls 3':  { color: '#6e7fa0', rgb: '110, 127, 160' },
              'Bloodborne':    { color: '#8b3a3a', rgb: '139, 58, 58' },
              'Elden Ring':    { color: '#c8a84e', rgb: '200, 168, 78' },
              "Demon's Souls": { color: '#8a8a8a', rgb: '138, 138, 138' },
            };
            const pgc = profileGameColorMap[trade.game] || { color: '#8a8a8a', rgb: '138, 138, 138' };
          %>
          <div class="trade-card">
            <% if (trade.game) { %>
              <div class="trade-card-banner" style="background: rgba(<%= pgc.rgb %>, 0.2); color: <%= pgc.color %>; border-bottom: 1px solid rgba(<%= pgc.rgb %>, 0.3);"><%= trade.game %></div>
            <% } %>
            <div class="offer-heading">
              Trade with
              <span style="<%= getUsernameStyle(partnerRole) %>"><%= partnerName %></span>
              <% if (completedDate) { %>
                <span class="time-ago"><%= completedDate %></span>
              <% } %>
            </div>

            <div class="trade-card-inner">
              <div class="offered-col">
                <h2>Offered</h2>
                <% offItems.forEach(item => {
                  const metaParts = [];
                  const _pq = fmtQty(item.qty); if (_pq) metaParts.push('\u00d7' + _pq);
                  if (item.upgrade !== null && item.upgrade !== undefined) metaParts.push('+' + item.upgrade);
                  const meta = metaParts.join(' ');
                %>
                  <div class="trade-item-row">
                    <% if (item.iconPath) { %>
                      <img class="trade-item-icon" src="<%= item.iconPath %>" alt="" onerror="this.style.display='none'">
                    <% } else { %>
                      <div class="trade-item-icon-fallback"><%= item.name.charAt(0) %></div>
                    <% } %>
                    <span class="trade-item-name"><%= item.name %></span>
                    <% if (meta) { %><span class="trade-item-meta"><%= meta %></span><% } %>
                  </div>
                <% }); %>
              </div>
              <div class="requested-col">
                <h2>Received</h2>
                <% reqItems.forEach(item => {
                  const metaParts = [];
                  const _pq = fmtQty(item.qty); if (_pq) metaParts.push('\u00d7' + _pq);
                  if (item.upgrade !== null && item.upgrade !== undefined) metaParts.push('+' + item.upgrade);
                  const meta = metaParts.join(' ');
                %>
                  <div class="trade-item-row">
                    <% if (item.iconPath) { %>
                      <img class="trade-item-icon" src="<%= item.iconPath %>" alt="" onerror="this.style.display='none'">
                    <% } else { %>
                      <div class="trade-item-icon-fallback"><%= item.name.charAt(0) %></div>
                    <% } %>
                    <span class="trade-item-name"><%= item.name %></span>
                    <% if (meta) { %><span class="trade-item-meta"><%= meta %></span><% } %>
                  </div>
                <% }); %>
              </div>
            </div>
          </div>
        <% }); %>
      <% } else { %>
        <p style="color: var(--text-muted); font-style:italic;">No completed trades yet.</p>
      <% } %>
    </div>
  </div>

    <!-- Trade Feedback -->
    <% if (typeof feedbackItems !== 'undefined' && feedbackItems.length > 0) { %>
      <div class="profile-section">
        <h2 class="profile-section-title">Trade Feedback (<%= feedbackItems.length %>)</h2>
        <div class="comment-list">
          <% feedbackItems.forEach(fb => { %>
            <div class="comment-card" style="border-left: 3px solid var(--success); background: rgba(34, 197, 94, 0.03);">
              <div class="comment-header">
                <div class="comment-author">
                  <div class="comment-avatar-fallback" style="background: rgba(34, 197, 94, 0.15); color: var(--success); font-size: 0.6rem;">TF</div>
                  <a href="/profile/<%= fb.authorUsername %>"
                     class="comment-author-name"
                     style="<%= getUsernameStyle(fb.authorRole) %>">
                    <%= fb.authorUsername %>
                  </a>
                  <span style="font-size:0.7rem; color:var(--text-muted); margin-left:0.25rem;">via trade</span>
                  <% if (fb.game) { %>
                    <span style="font-size:0.68rem; color:var(--text-muted); opacity:0.7; margin-left:0.25rem;">(<%= fb.game %>)</span>
                  <% } %>
                </div>
                <div class="comment-meta">
                  <span class="comment-date"><%= fb.date.toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' }) %></span>
                </div>
              </div>
              <div class="comment-body"><%= fb.content %></div>
            </div>
          <% }); %>
        </div>
      </div>
    <% } %>

    <!-- Profile Comments -->
    <div class="profile-section">
      <h2 class="profile-section-title">Comments (<%= typeof totalComments !== 'undefined' ? totalComments : 0 %>)</h2>

      <% if (typeof query !== 'undefined' && query.error) { %>
        <p style="color:var(--danger); font-size:0.85rem; margin-bottom:1rem;"><%= query.error %></p>
      <% } %>

      <!-- Comment form (logged-in users only) -->
      <% if (typeof userId !== 'undefined' && userId) { %>
        <form action="/comments/<%= profileUser.id %>" method="POST" class="comment-form">
          <textarea name="content" maxlength="500" rows="3" placeholder="Leave a comment..." required></textarea>
          <div style="display:flex; justify-content:space-between; align-items:center; margin-top:0.5rem;">
            <span style="font-size:0.72rem; color:var(--text-muted);">Max 500 characters. No links or hate speech.</span>
            <button type="submit" class="btn btn-primary btn-sm">Post</button>
          </div>
        </form>
      <% } else { %>
        <p style="color:var(--text-muted); font-size:0.85rem; font-style:italic;">Log in to leave a comment.</p>
      <% } %>

      <!-- Comment list -->
      <div class="comment-list">
        <% if (typeof comments !== 'undefined' && comments.length > 0) { %>
          <% comments.forEach(comment => { %>
            <div class="comment-card" id="comment-<%= comment.id %>">
              <div class="comment-header">
                <div class="comment-author">
                  <% if (comment.author && comment.author.profileImagePath) { %>
                    <img src="<%= comment.author.profileImagePath %>" class="comment-avatar" alt="" onerror="this.style.display='none'">
                  <% } else { %>
                    <div class="comment-avatar-fallback"><%= comment.author ? comment.author.username.charAt(0).toUpperCase() : '?' %></div>
                  <% } %>
                  <a href="/profile/<%= comment.author ? comment.author.username : '' %>"
                     class="comment-author-name"
                     style="<%= comment.author ? getUsernameStyle(comment.author.role) : '' %>">
                    <%= comment.author ? comment.author.username : 'Unknown' %>
                  </a>
                </div>
                <div class="comment-meta">
                  <span class="comment-date"><%= comment.createdAt.toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' }) %></span>
                  <% if (comment.editedAt) { %>
                    <span class="comment-edited">(edited)</span>
                  <% } %>
                </div>
              </div>
              <div class="comment-body" id="comment-body-<%= comment.id %>"><%= comment.content %></div>
              <div class="comment-actions">
                <% const canEdit   = typeof userId !== 'undefined' && userId && comment.author && comment.authorId === userId; %>
                <% const canDelete = typeof userId !== 'undefined' && userId && (comment.authorId === userId || profileUser.id === userId || role === 'admin'); %>
                <% if (canEdit) { %>
                  <button class="comment-action-btn" onclick="editComment('<%= comment.id %>')">Edit</button>
                <% } %>
                <% if (canDelete) { %>
                  <button class="comment-action-btn comment-delete-btn" onclick="deleteComment('<%= comment.id %>')">Delete</button>
                <% } %>
              </div>
            </div>
          <% }); %>
        <% } else { %>
          <p style="color:var(--text-muted); font-style:italic; margin-top:1rem;">No comments yet.</p>
        <% } %>
      </div>

      <!-- Comment pagination -->
      <% if (typeof totalCommentPages !== 'undefined' && totalCommentPages > 1) { %>
        <div class="pagination" style="margin-top:1rem;">
          <% for (let i = 1; i <= totalCommentPages; i++) { %>
            <a href="/profile/<%= profileUser.username %>?commentPage=<%= i %>"
               class="pagination-btn <%= (typeof commentPage !== 'undefined' ? commentPage : 1) === i ? 'active' : '' %>"><%= i %></a>
          <% } %>
        </div>
      <% } %>
    </div>
  </div>

  <%- include('partials/auth-modals') %>
  <%- include('partials/footer') %>
  <script src="/js/auth.js"></script>
  <script src="/js/user-hover.js"></script>
  <script>
    function toggleProfileEdit() {
      document.getElementById('profileEditPanel').classList.toggle('open');
    }

    async function editComment(commentId) {
      const bodyEl = document.getElementById('comment-body-' + commentId);
      const current = bodyEl.textContent.trim();
      const newText = prompt('Edit your comment:', current);
      if (newText === null || newText.trim() === current) return;

      try {
        const resp = await fetch('/comments/' + commentId, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ content: newText }),
        });
        const data = await resp.json();
        if (data.success) {
          bodyEl.textContent = data.content;
          // Add (edited) indicator
          const meta = bodyEl.closest('.comment-card').querySelector('.comment-meta');
          if (!meta.querySelector('.comment-edited')) {
            const ed = document.createElement('span');
            ed.className = 'comment-edited';
            ed.textContent = '(edited)';
            meta.appendChild(ed);
          }
        } else {
          alert(data.error || 'Failed to edit comment.');
        }
      } catch { alert('Network error.'); }
    }

    async function deleteComment(commentId) {
      if (!confirm('Delete this comment?')) return;
      try {
        const resp = await fetch('/comments/' + commentId, { method: 'DELETE' });
        const data = await resp.json();
        if (data.success) {
          document.getElementById('comment-' + commentId).remove();
        } else {
          alert(data.error || 'Failed to delete comment.');
        }
      } catch { alert('Network error.'); }
    }
  </script>
</body>
</html>
